@{
    Layout = null;
    ViewData["Title"] = "Login - LogiTrack";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LogiTrack — Sign In</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'DM Sans', sans-serif;
            width: 100vw;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        .font-mono {
            font-family: 'JetBrains Mono', monospace;
        }
        
        .font-display {
            font-family: 'Barlow Condensed', sans-serif;
        }
        
        .gradient-accent {
            background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%);
        }
        
        .gradient-button {
            background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%);
        }
        
        .gradient-button:hover {
            background: linear-gradient(135deg, #1d4ed8 0%, #0891b2 100%);
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(37, 99, 235, 0.25);
        }
        
        @@keyframes floatIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @@keyframes pulse-soft {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.6;
            }
        }
        
        .float-in {
            animation: floatIn 0.6s ease-out both;
        }
        
        .slide-in-left {
            animation: slideInLeft 0.7s ease-out both;
        }
        
        .slide-in-right {
            animation: slideInRight 0.7s ease-out both;
        }
        
        .pulse-soft {
            animation: pulse-soft 3s ease-in-out infinite;
        }
        
        .input-focus {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .input-focus:focus {
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15), inset 0 0 0 1px rgba(37, 99, 235, 0.55);
            transform: translateY(-2px);
        }
        
        button, input, select, textarea {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Background image with overlay - STATIC */
        .login-bg {
            background-image: url('@Url.Content("~/Images/login.jpg")');
            background-size: cover;
            background-position: center;
            background-attachment: scroll;
            position: relative;
        }

        .login-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.85) 0%, rgba(6, 182, 212, 0.75) 100%);
            pointer-events: none;
        }

        .login-bg > * {
            position: relative;
            z-index: 10;
        }
        </style>
</head>
<body class="bg-slate-50">

    <!-- NAVBAR -->
    <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-lg overflow-hidden flex items-center justify-center shadow-sm">
                    <img src="~/Images/Logo.png" alt="LogiTrack" class="object-contain w-full h-full" />
                </div>
                <div>
                    <div class="font-display font-bold text-xl text-slate-900">LogiTrack</div>
                    <div class="text-xs text-sky-600 font-mono">Track Smart. Deliver Faster.</div>
                </div>
            </a>

            <div class="hidden md:flex items-center gap-8">
                <a href="/" class="text-sm hover:text-sky-600 transition text-slate-700">Home</a>
                <a href="/#services" class="text-sm hover:text-sky-600 transition text-slate-700">Services</a>
                <a href="/#features" class="text-sm hover:text-sky-600 transition text-slate-700">Features</a>
            </div>

        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="min-h-screen flex items-center justify-center py-12 px-4">
        <div class="w-full max-w-4xl">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">

                    <!-- LEFT SIDE - BENEFITS WITH BACKGROUND IMAGE (STATIC) -->
                    <div class="hidden lg:flex flex-col justify-center login-bg p-12 border-r border-slate-200 min-h-screen">
                        <div class="slide-in-left space-y-8">
                            <div>
                                <h2 class="font-display text-4xl font-bold text-white mb-2">Welcome back</h2>
                                <p class="text-white/90 text-lg">Sign in to continue to your dashboard</p>
                            </div>

                            <div class="space-y-6">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white flex-shrink-0 mt-1">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-white">Faster operations</h3>
                                        <p class="text-sm text-white/80">Plan, track, and optimize in one place</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white flex-shrink-0 mt-1">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-white">Secure access</h3>
                                        <p class="text-sm text-white/80">Role-based access with audit logs</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white flex-shrink-0 mt-1">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-white">Real-time visibility</h3>
                                        <p class="text-sm text-white/80">Live shipment status and tracking events</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT SIDE - FORM -->
                    <div class="p-10 lg:p-14 slide-in-right">
                        <h2 class="font-display text-3xl font-bold text-slate-900 mb-2">Sign In</h2>
                        <p class="text-slate-600 mb-8">Welcome back to LogiTrack</p>

                        <form method="post" action="@Url.Action("Login", "Account")" class="space-y-5">
                            @Html.AntiForgeryToken()

                            <!-- Error Message -->
                            @if (ViewBag.Error != null)
                            {
                                <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm flex items-center gap-3">
                                    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m6-6a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    <span>@ViewBag.Error</span>
                                </div>
                            }

                            @if (TempData["Success"] != null)
                            {
                                <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-lg text-emerald-700 text-sm flex items-center gap-3">
                                    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    <span>@TempData["Success"]</span>
                                </div>
                            }

                            <!-- Email -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Email Address <span class="text-red-500">*</span></label>
                                <input type="email" name="Email" required maxlength="100" placeholder="you@company.com"
                                       class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg px-4 py-2.5 text-sm outline-none transition-all" />
                            </div>

                            <!-- Password -->
                            <div>
                                <div class="flex items-center justify-between mb-2">
                                    <label class="block text-sm font-semibold text-slate-700">Password <span class="text-red-500">*</span></label>
                                    <a href="@Url.Action("ForgotPassword", "Account")" class="text-sm text-sky-600 hover:text-sky-700 font-semibold">Forgot?</a>
                                </div>
                                <input type="password" name="Password" required maxlength="128" placeholder="••••••••••"
                                       class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg px-4 py-2.5 text-sm outline-none transition-all" />
                            </div>

                            <!-- Remember me -->
                            <label class="flex items-center gap-3 cursor-pointer pt-1">
                                <input type="checkbox" name="RememberMe" class="w-5 h-5 rounded accent-sky-500 bg-slate-50 border-slate-300" />
                                <span class="text-sm text-slate-600">Keep me signed in</span>
                            </label>

                            <!-- Sign in Button -->
                            <button type="submit"
                                    class="w-full gradient-button text-white font-semibold py-3 rounded-lg transition-all text-sm hover:shadow-lg hover:shadow-sky-500/20 mt-6">
                                Sign In
                            </button>


                        </form>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center mt-8 text-sm text-slate-600">
                <p>&copy; 2024 LogiTrack. All rights reserved.</p>
            </div>
        </div>
    </div>
</body>
</html>
