@{
    Layout = null;
    ViewData["Title"] = "Register - LogiTrack";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LogiTrack — Create Account</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'DM Sans', sans-serif;
            width: 100vw;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        .font-mono {
            font-family: 'JetBrains Mono', monospace;
        }
        
        .font-display {
            font-family: 'Barlow Condensed', sans-serif;
        }
        
        .gradient-accent {
            background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        }
        
        .gradient-button {
            background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        }
        
        .gradient-button:hover {
            background: linear-gradient(135deg, #ea580c 0%, #f97316 100%);
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(249, 115, 22, 0.3);
        }
        
        @@keyframes floatIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        .float-in {
            animation: floatIn 0.6s ease-out both;
        }
        
        .slide-in-left {
            animation: slideInLeft 0.7s ease-out both;
        }
        
        .slide-in-right {
            animation: slideInRight 0.7s ease-out both;
        }

        /* Background image with overlay - STATIC, NO PARALLAX */
        .register-bg {
            background-image: url('@Url.Content("~/Images/register.jpg")');
            background-size: cover;
            background-position: center;
            background-attachment: scroll;
            position: relative;
        }

        .register-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(249, 115, 22, 0.85) 0%, rgba(251, 146, 60, 0.75) 100%);
            pointer-events: none;
        }

        .register-bg > * {
            position: relative;
            z-index: 10;
        }
    </style>
</head>
<body class="bg-slate-50">

    <!-- NAVBAR -->
    <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-lg overflow-hidden flex items-center justify-center shadow-sm">
                    <img src="~/Images/Logo.png" alt="LogiTrack" class="object-contain w-full h-full" />
                </div>
                <div>
                    <div class="font-display font-bold text-xl text-slate-900">LogiTrack</div>
                    <div class="text-xs text-orange-600 font-mono">Track Smart. Deliver Faster.</div>
                </div>
            </a>

            <div class="hidden md:flex items-center gap-8">
                <a href="/" class="text-sm hover:text-orange-600 transition text-slate-700">Home</a>
                <a href="/#services" class="text-sm hover:text-orange-600 transition text-slate-700">Services</a>
                <a href="/#features" class="text-sm hover:text-orange-600 transition text-slate-700">Features</a>
            </div>

        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="min-h-screen flex items-center justify-center py-12 px-4">
        <div class="w-full max-w-4xl">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
                    
                    <!-- LEFT SIDE - BENEFITS WITH BACKGROUND IMAGE (STATIC) -->
                    <div class="hidden lg:flex flex-col justify-center register-bg p-12 border-r border-slate-200 min-h-screen">
                        <div class="slide-in-left space-y-8">
                            <div>
                                <h2 class="font-display text-4xl font-bold text-white mb-2">Join LogiTrack</h2>
                                <p class="text-white/90 text-lg">Start optimizing your logistics operations today</p>
                            </div>

                            <div class="space-y-6">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white flex-shrink-0 mt-1">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-white">Real-time Tracking</h3>
                                        <p class="text-sm text-white/80">Monitor shipments in real-time</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white flex-shrink-0 mt-1">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-white">Route Optimization</h3>
                                        <p class="text-sm text-white/80">Reduce costs with smart routing</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white flex-shrink-0 mt-1">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold text-white">24/7 Support</h3>
                                        <p class="text-sm text-white/80">Get help whenever you need it</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT SIDE - FORM -->
                    <div class="p-10 lg:p-14 slide-in-right">
                        <h2 class="font-display text-3xl font-bold text-slate-900 mb-2">Create Account</h2>
                        <p class="text-slate-600 mb-8">Get started with LogiTrack today</p>

                        <form method="post" action="@Url.Action("Register", "Account")" class="space-y-5">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SelectedPlan" value="@ViewBag.SelectedPlan" />
                            <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

                            @if (ViewBag.SelectedPlan != null)
                            {
                                <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg text-blue-700 text-sm">
                                    You selected the <strong>@ViewBag.SelectedPlan</strong> plan. Finish account creation to continue to payment.
                                </div>
                            }

                            <!-- Error Message -->
                            @if (ViewBag.Error != null)
                            {
                                <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm flex items-center gap-3">
                                    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m6-6a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    <span>@ViewBag.Error</span>
                                </div>
                            }

                            <!-- Success Message -->
                            @if (ViewBag.Success != null)
                            {
                                <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-lg text-emerald-700 text-sm flex items-center gap-3">
                                    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    <span>@ViewBag.Success</span>
                                </div>
                            }

                            <!-- Full Name -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Full Name <span class="text-red-500">*</span></label>
                                <input type="text" name="FullName" required maxlength="100" placeholder="John Doe"
                                       class="w-full bg-slate-50 border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg px-4 py-2.5 text-sm outline-none transition-all" />
                                @Html.ValidationMessage("FullName", new { @class = "text-xs text-red-600 mt-2 block" })
                            </div>

                            <!-- Email -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Email Address <span class="text-red-500">*</span></label>
                                <input type="email" name="Email" required maxlength="100" placeholder="you@company.com"
                                       class="w-full bg-slate-50 border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg px-4 py-2.5 text-sm outline-none transition-all" />
                                @Html.ValidationMessage("Email", new { @class = "text-xs text-red-600 mt-2 block" })
                            </div>

                            <!-- Password -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Password <span class="text-red-500">*</span></label>
                                <input type="password" name="Password" required minlength="8" maxlength="128" placeholder="At least 8 characters"
                                       class="w-full bg-slate-50 border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg px-4 py-2.5 text-sm outline-none transition-all" />
                                <p class="text-xs text-slate-500 mt-1">Use at least 8 characters with uppercase, lowercase, and numbers</p>
                                @Html.ValidationMessage("Password", new { @class = "text-xs text-red-600 mt-2 block" })
                            </div>

                            <!-- Confirm Password -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Confirm Password <span class="text-red-500">*</span></label>
                                <input type="password" name="ConfirmPassword" required minlength="8" maxlength="128" placeholder="Confirm your password"
                                       class="w-full bg-slate-50 border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg px-4 py-2.5 text-sm outline-none transition-all" />
                                @Html.ValidationMessage("ConfirmPassword", new { @class = "text-xs text-red-600 mt-2 block" })
                            </div>

                            <!-- Terms and Conditions -->
                            <label class="flex items-start gap-3 cursor-pointer pt-2">
                                <input type="checkbox" name="AgreeTerms" value="true" required class="w-5 h-5 rounded accent-orange-500 bg-slate-50 border-slate-300 mt-0.5"
                                       />
                                <span class="text-sm text-slate-600">
                                    I agree to the <a href="#" class="text-orange-600 hover:text-orange-700 font-semibold">Terms of Service</a> 
                                    and <a href="#" class="text-orange-600 hover:text-orange-700 font-semibold">Privacy Policy</a>
                                </span>
                            </label>
                            @Html.ValidationMessage("AgreeTerms", new { @class = "text-xs text-red-600 mt-1 block" })

                            <!-- Register Button -->
                            <button type="submit" 
                                    class="w-full gradient-button text-white font-semibold py-3 rounded-lg transition-all text-sm hover:shadow-lg hover:shadow-orange-500/20 mt-8">
                                Create Account
                            </button>

                            <!-- Login Link -->
                            <div class="text-center pt-4 border-t border-slate-200">
                                <p class="text-sm text-slate-600">
                                    Already have an account? 
                                    <a href="@Url.Action("Login", "Account")" class="text-orange-600 hover:text-orange-700 font-semibold">Sign In</a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center mt-8 text-sm text-slate-600">
                <p>&copy; 2024 LogiTrack. All rights reserved.</p>
            </div>
        </div>
    </div>

</body>
</html>