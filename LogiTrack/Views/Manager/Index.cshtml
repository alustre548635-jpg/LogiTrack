@model LogiTrack.Models.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Manager Dashboard";
    ViewData["ActiveNav"] = "dashboard";
    Layout = "_ModuleLayout";
}

<div x-data="{ showAllLogs: false }" class="space-y-6">
    <div class="mb-2">
        <h2 class="font-display text-4xl font-bold uppercase tracking-wide">Dashboard</h2>
        <p class="text-slate-600">Overview of operational shipments and recent activity.</p>
    </div>

    <section class="space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
            <div class="rounded-2xl bg-white border border-slate-200 p-5 shadow-sm">
                <p class="text-xs text-slate-500 uppercase tracking-wider font-bold">Total Shipments</p>
                <p class="text-3xl font-bold mt-2 text-slate-900">@Model.TotalShipments</p>
            </div>
            <div class="rounded-2xl bg-amber-50 border border-amber-100 p-5 shadow-sm">
                <p class="text-xs text-amber-600 uppercase tracking-wider font-bold flex items-center justify-between">
                    Pending 
                    <svg class="w-4 h-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </p>
                <p class="text-3xl font-bold text-amber-600 mt-2">@Model.PendingShipments</p>
            </div>
            <div class="rounded-2xl bg-cyan-50 border border-cyan-100 p-5 shadow-sm">
                <p class="text-xs text-cyan-600 uppercase tracking-wider font-bold flex items-center justify-between">
                    In Transit 
                    <svg class="w-4 h-4 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
                </p>
                <p class="text-3xl font-bold text-cyan-600 mt-2">@Model.InTransitShipments</p>
            </div>
            <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-5 shadow-sm">
                <p class="text-xs text-emerald-600 uppercase tracking-wider font-bold flex items-center justify-between">
                    Delivered 
                    <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </p>
                <p class="text-3xl font-bold text-emerald-600 mt-2">@Model.DeliveredShipments</p>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            @* Recent Shipments Card *@
            <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                    <h3 class="font-display text-xl font-bold text-slate-900 uppercase">Recent Shipments</h3>
                    <a href="@Url.Action("Index", "Shipment")" class="text-xs font-bold text-sky-600 hover:text-sky-500 uppercase tracking-wider">Manage All</a>
                </div>
                <div class="divide-y divide-slate-100 max-h-[400px] overflow-y-auto">
                    @if (Model.RecentShipments.Count == 0)
                    {
                        <p class="px-6 py-10 text-center text-slate-500">No shipments found.</p>
                    }
                    else
                    {
                        @foreach (var shipment in Model.RecentShipments)
                        {
                            <div class="px-6 py-4 flex items-center justify-between gap-4 hover:bg-slate-50 transition-colors">
                                <div>
                                    <p class="font-bold text-slate-900">@shipment.ShipmentCode</p>
                                    <p class="text-xs text-slate-500 font-medium">@shipment.Origin → @shipment.Destination</p>
                                </div>
                                @{
                                    var statusClass = shipment.Status == "In Transit" ? "text-cyan-700 bg-cyan-100" :
                                        (shipment.Status == "Delivered" || shipment.Status == "Completed") ? "text-emerald-700 bg-emerald-100" :
                                        shipment.Status == "Cancelled" ? "text-red-700 bg-red-100" :
                                        "text-amber-700 bg-amber-100";
                                }
                                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider @statusClass">@shipment.Status</span>
                            </div>
                        }
                    }
                </div>
            </div>

            @* Recent Activity Card *@
            <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                    <h3 class="font-display text-xl font-bold text-slate-900 uppercase">System Activity</h3>
                    <button @@click="showAllLogs = true" class="text-xs font-bold text-sky-600 hover:text-sky-500 uppercase tracking-wider">View History</button>
                </div>
                <div class="divide-y divide-slate-100 max-h-[400px] overflow-y-auto">
                    @if (Model.RecentActivities.Count == 0)
                    {
                        <p class="px-6 py-10 text-center text-slate-500">No system activity logged.</p>
                    }
                    else
                    {
                        @foreach (var activity in Model.RecentActivities.Take(10))
                        {
                            <div class="px-6 py-4 flex items-center justify-between gap-4 group hover:bg-slate-50 transition-colors">
                                <div class="flex-1">
                                    <p class="text-sm font-bold text-slate-800">@activity.Action</p>
                                    <div class="flex items-center gap-2 mt-0.5">
                                        <span class="text-[10px] text-slate-400 uppercase font-black">By @(activity.User?.FullName ?? "System")</span>
                                        <span class="text-slate-300">•</span>
                                        <span class="text-[10px] text-sky-500 font-bold">@activity.TableAffected</span>
                                    </div>
                                </div>
                                <span class="text-xs text-slate-400 font-medium whitespace-nowrap">@activity.Timestamp.ToString("MMM dd, HH:mm")</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    @* FULL AUDIT LOGS MODAL *@
    <div x-show="showAllLogs" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-md p-4" style="display:none;" x-cloak>
        <div @@click.away="showAllLogs = false" class="bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden animate-[fadeScaleIn_0.2s_ease-out] flex flex-col max-h-[85vh]">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50 flex-shrink-0">
                <div>
                    <h3 class="text-2xl font-display font-bold text-slate-900 uppercase tracking-tight">Full Activity Audit Log</h3>
                    <p class="text-xs text-slate-500 font-medium uppercase tracking-widest mt-1">Operational History Oversight</p>
                </div>
                <button @@click="showAllLogs = false" class="text-slate-400 hover:text-slate-600 text-3xl leading-none transition-colors">&times;</button>
            </div>
            <div class="overflow-y-auto flex-1 divide-y divide-slate-100 bg-white">
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="px-8 py-5 hover:bg-slate-50 transition-colors">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="font-bold text-slate-900 text-base">@activity.Action</p>
                                <div class="flex items-center gap-3 mt-2">
                                    <div class="flex items-center gap-1.5 bg-slate-100 px-2 py-1 rounded-md">
                                        <span class="text-[10px] font-bold text-slate-400 uppercase">User</span>
                                        <span class="text-xs font-bold text-slate-700">@(activity.User?.FullName ?? "System")</span>
                                    </div>
                                    <div class="flex items-center gap-1.5 bg-sky-50 px-2 py-1 rounded-md">
                                        <span class="text-[10px] font-bold text-sky-400 uppercase">Entity</span>
                                        <span class="text-xs font-bold text-sky-700">@activity.TableAffected</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-right">
                                <span class="text-[11px] font-black text-slate-400 bg-slate-50 px-2 py-1 border border-slate-100 rounded-lg whitespace-nowrap font-mono">@activity.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                <p class="text-[10px] text-slate-400 mt-1 italic">IP: @(activity.IPAddress ?? "0.0.0.0")</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 flex justify-end flex-shrink-0">
                <button @@click="showAllLogs = false" class="px-8 py-2.5 bg-slate-900 text-white font-bold rounded-xl hover:bg-slate-800 transition shadow-lg shadow-slate-900/20">Close Logs</button>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeScaleIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
    [x-cloak] { display: none !important; }
</style>
