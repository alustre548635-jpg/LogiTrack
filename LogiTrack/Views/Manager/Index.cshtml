@model LogiTrack.Models.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Manager Dashboard";
    ViewData["ActiveNav"] = "dashboard";
    Layout = "_ModuleLayout";
}
<div class="space-y-6">
    <div class="mb-2">
        <h2 class="font-display text-4xl font-bold">Manager Dashboard</h2>
        <p class="text-slate-600">Overview of operational shipments and recent activity.</p>
    </div>

    <section class="space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
            <div class="rounded-2xl bg-white border border-slate-200 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wider">Total Shipments</p>
                <p class="text-3xl font-bold mt-2">@Model.TotalShipments</p>
            </div>
            <div class="rounded-2xl bg-white border border-slate-200 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wider">Pending</p>
                <p class="text-3xl font-bold mt-2">@Model.PendingShipments</p>
            </div>
            <div class="rounded-2xl bg-white border border-slate-200 p-5">
                <p class="text-xs text-slate-500 uppercase tracking-wider">In Transit</p>
                <p class="text-3xl font-bold mt-2">@Model.InTransitShipments</p>
            </div>
            <div class="rounded-2xl gradient-accent text-white p-5">
                <p class="text-xs uppercase tracking-wider text-white/80">Delivered</p>
                <p class="text-3xl font-bold mt-2">@Model.DeliveredShipments</p>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <div class="rounded-2xl bg-white border border-slate-200">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h3 class="font-display text-2xl font-bold">Recent Shipments</h3>
                </div>
                <div class="divide-y divide-slate-100">
                    @if (Model.RecentShipments.Count == 0)
                    {
                        <p class="px-6 py-6 text-slate-500">No shipments yet.</p>
                    }
                    else
                    {
                        @foreach (var shipment in Model.RecentShipments)
                        {
                            <div class="px-6 py-4 flex items-center justify-between gap-4">
                                <div>
                                    <p class="font-semibold text-slate-900">@shipment.ShipmentCode</p>
                                    <p class="text-sm text-slate-500">@shipment.Origin → @shipment.Destination</p>
                                </div>
                                <span class="px-2 py-1 rounded-full text-xs bg-slate-100 text-slate-700">@shipment.Status</span>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="rounded-2xl bg-white border border-slate-200">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h3 class="font-display text-2xl font-bold">Recent Activity</h3>
                </div>
                <div class="divide-y divide-slate-100">
                    @if (Model.RecentActivities.Count == 0)
                    {
                        <p class="px-6 py-6 text-slate-500">No recent activity.</p>
                    }
                    else
                    {
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <div class="px-6 py-4">
                                <div class="flex items-start justify-between gap-4">
                                    <p class="text-sm text-slate-800">@activity.Action</p>
                                    <span class="text-xs text-slate-400 whitespace-nowrap">@activity.Timestamp.ToString("MMM dd, hh:mm tt")</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>
</div>

