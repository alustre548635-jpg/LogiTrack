<script>
    function showSystemToast(message, type = 'success') {
        const existing = document.getElementById('system-toast');
        if (existing) {
            existing.remove();
        }

        const toast = document.createElement('div');
        toast.id = 'system-toast';
        toast.className = type === 'success'
            ? 'fixed top-5 right-5 z-50 max-w-sm rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-700 text-sm font-medium shadow-lg'
            : 'fixed top-5 right-5 z-50 max-w-sm rounded-xl border border-red-200 bg-red-50 p-4 text-red-700 text-sm font-medium shadow-lg';

        const iconPath = type === 'success'
            ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />'
            : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />';

        toast.innerHTML = `
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    ${iconPath}
                </svg>
                <span class="flex-1"></span>
                <button type="button" class="hover:opacity-80">&times;</button>
            </div>
        `;

        toast.querySelector('span').textContent = message;
        toast.querySelector('button').addEventListener('click', () => toast.remove());
        document.body.appendChild(toast);
        setTimeout(() => {
            if (toast.parentElement) {
                toast.remove();
            }
        }, 3500);
    }

    function showSystemConfirm(message, confirmLabel = 'Confirm') {
        return new Promise((resolve) => {
            const existing = document.getElementById('system-confirm-overlay');
            if (existing) {
                existing.remove();
            }

            const overlay = document.createElement('div');
            overlay.id = 'system-confirm-overlay';
            overlay.className = 'fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4';

            overlay.innerHTML = `
                <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">
                    <div class="flex items-start gap-3">
                        <div class="mt-0.5 rounded-full bg-amber-100 p-2 text-amber-600">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h3 class="text-base font-semibold text-slate-900">Confirm Action</h3>
                            <p class="mt-1 text-sm text-slate-600"></p>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end gap-2">
                        <button type="button" data-action="cancel" class="rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200 transition-colors">
                            Keep Shipment
                        </button>
                        <button type="button" data-action="confirm" class="rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500 transition-colors">
                            ${confirmLabel}
                        </button>
                    </div>
                </div>
            `;

            overlay.querySelector('p').textContent = message;
            overlay.querySelector('[data-action="cancel"]').addEventListener('click', () => {
                overlay.remove();
                resolve(false);
            });
            overlay.querySelector('[data-action="confirm"]').addEventListener('click', () => {
                overlay.remove();
                resolve(true);
            });
            overlay.addEventListener('click', (event) => {
                if (event.target === overlay) {
                    overlay.remove();
                    resolve(false);
                }
            });

            document.body.appendChild(overlay);
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        const successMessage = sessionStorage.getItem('shipmentSuccessToast');
        if (successMessage) {
            showSystemToast(successMessage, 'success');
            sessionStorage.removeItem('shipmentSuccessToast');
        }
    });

    function approveShipment(id) {
        if (!confirm('Approve this shipment?')) return;
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const payload = new FormData();
        payload.append('shipmentId', id);

        fetch('/Shipment/Approve', {
            method: 'POST',
            headers: tokenInput ? { 'RequestVerificationToken': tokenInput.value } : {},
            body: payload
        }).then(r => r.json()).then(d => {
            if (d.success) {
                location.reload();
            } else {
                alert(d.message || 'Unable to approve shipment.');
            }
        });
    }

    function submitCreateShipment(e) {
        e.preventDefault();
        const form = document.getElementById('createShipmentForm');
        const data = new FormData(form);
        fetch('/Shipment/Create', { method: 'POST', body: data })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    location.reload();
                } else {
                    alert(d.message || 'Unable to create shipment.');
                }
            });
    }

    function submitEditShipment(e) {
        e.preventDefault();
        const form = document.getElementById('editShipmentForm');
        const data = new FormData(form);
        fetch('/Shipment/Update', { method: 'POST', body: data })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    sessionStorage.setItem('shipmentSuccessToast', d.message || 'Shipment updated successfully.');
                    location.reload();
                } else {
                    alert(d.message || 'Unable to update shipment.');
                }
            });
    }

    async function cancelShipment(id) {
        const confirmed = await showSystemConfirm('Cancel this shipment?', 'Cancel Shipment');
        if (!confirmed) return;

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const payload = new FormData();
        payload.append('shipmentId', id);
        if (tokenInput && tokenInput.value) {
            payload.append('__RequestVerificationToken', tokenInput.value);
        }

        fetch('/Shipment/Cancel', {
            method: 'POST',
            headers: tokenInput ? { 'RequestVerificationToken': tokenInput.value } : {},
            body: payload
        }).then(r => r.json()).then(d => {
            if (d.success) {
                sessionStorage.setItem('shipmentSuccessToast', d.message || 'Shipment cancelled.');
                location.reload();
            } else {
                showSystemToast(d.message || 'Unable to cancel shipment.', 'error');
            }
        }).catch(() => {
            showSystemToast('Unable to cancel shipment.', 'error');
        });
    }
</script>
</body>
</html>
