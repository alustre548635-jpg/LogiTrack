                                        'text-amber-600': selectedShipment.status === 'Pending',
                                        'text-teal-600': selectedShipment.status === 'In Transit' || selectedShipment.status === 'Received at Warehouse',
                                        'text-emerald-600': selectedShipment.status === 'Delivered' || selectedShipment.status === 'Completed',
                                        'text-rose-600': selectedShipment.status === 'Cancelled',
                                        'text-slate-700': selectedShipment.status !== 'Pending' && selectedShipment.status !== 'In Transit' && selectedShipment.status !== 'Received at Warehouse' && selectedShipment.status !== 'Delivered' && selectedShipment.status !== 'Completed' && selectedShipment.status !== 'Cancelled'
                                    }" x-text="selectedShipment.status"></p>
