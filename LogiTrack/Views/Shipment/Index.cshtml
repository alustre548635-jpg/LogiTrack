                            @* Management Actions *@
                            @if (isManagerOrAdmin)
                            {
                                <template x-if="selectedShipment.status === 'Pending'">
                                    <div class="pt-2 border-t border-slate-200 space-y-4">
                                        <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-[0.12em] border-b border-slate-200 pb-2">Management Actions</p>
                                        <div class="flex flex-wrap gap-3">
                                            <button type="button" @@click="editShipment()" class="min-w-0 flex-1 basis-[140px] px-6 py-3 bg-sky-600 text-white text-sm font-bold rounded-xl hover:bg-sky-500 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                                                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                                Edit
                                            </button>
                                            <button type="button" @@click="cancelShipment(selectedShipment.shipmentId)" class="min-w-0 flex-1 basis-[140px] px-6 py-3 bg-slate-100 text-slate-700 text-sm font-bold rounded-xl hover:bg-slate-200 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                                                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
