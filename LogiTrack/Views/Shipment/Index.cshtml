                                    <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-[0.12em]">Assigned Warehouse</p>
                                    <p class="mt-1 text-sm font-bold text-slate-900" x-text="selectedShipment.warehouseName"></p>
                                </div>
                            </div>

                            @* Cargo Information *@
                            <div class="space-y-4">
                                <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-[0.12em] border-b border-slate-200 pb-2">Cargo Information</p>
                                <div class="grid grid-cols-2 gap-x-6 gap-y-5">
