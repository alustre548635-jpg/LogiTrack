</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function shipmentModule() {
        return {
            showCreatePanel: false,
            isEditing: false,
            showViewPanel: false,
            selectedShipment: {},
            searchText: '',
            statusFilter: '',
            statusFilterGroup: '',
            carrierFilter: '',
            dateFilter: '',
            sortShipmentAsc: false,
            carriers: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Carriers)),
            warehouses: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Warehouses)),
            rateCards: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RateCards)),
            kpis: {
                totalToday: @Model.TotalToday,
                pending: @Model.PendingApproval,
                inTransit: @Model.InTransit,
                completed: @Model.Completed
            },
            newShipmentWeight: 0,
            newShipmentCarrierId: '',
            newShipmentDest: '',
            newShipmentPriority: 'Standard',
            newShipmentShippingFee: 0,
            newShipmentEstimatedCost: 0,
            editingShipmentId: '',
            editingShipmentCode: '',
            editingShipmentStatus: '',

            formatFormProfit(fee, cost) {
                const n = (parseFloat(fee) || 0) - (parseFloat(cost) || 0);
                return '₱' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            },

            getAntiForgeryToken() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            },

            antiforgeryHeaders() {
                const t = this.getAntiForgeryToken();
                return t ? { '__RequestVerificationToken': t, 'X-Requested-With': 'XMLHttpRequest' } : { 'X-Requested-With': 'XMLHttpRequest' };
            },

            applyKpiFilter(mode) {
                this.carrierFilter = '';
                this.dateFilter = '';
                this.searchText = '';
                if (mode === 'all') {
                    this.statusFilter = '';
                    this.statusFilterGroup = '';
                    window.showToast?.('Showing all statuses', 'info');
                    return;
                }
                if (mode === 'Completed') {
                    this.statusFilter = '';
                    this.statusFilterGroup = 'terminal';
                    window.showToast?.('Showing delivered & completed', 'info');
                    return;
                }
                this.statusFilterGroup = '';
                this.statusFilter = mode;
            },

            rowMatches(el) {
                const code = (el.dataset.code || '').toLowerCase();
                const origin = (el.dataset.origin || '').toLowerCase();
                const dest = (el.dataset.destination || '').toLowerCase();
                const carrier = (el.dataset.carrier || '').toLowerCase();
                const status = el.dataset.status || '';
                const scheduled = el.dataset.scheduled || '';
                const search = this.searchText.toLowerCase();
                const matchText = !search || code.includes(search) || origin.includes(search) || dest.includes(search) || carrier.includes(search);
                let matchStatus = true;
                if (this.statusFilterGroup === 'terminal') {
                    matchStatus = status === 'Delivered' || status === 'Completed';
                } else if (this.statusFilter) {
                    matchStatus = status === this.statusFilter;
                }
                const matchCarrier = !this.carrierFilter || (el.dataset.carrier || '') === this.carrierFilter;
                const matchDate = !this.dateFilter || scheduled === this.dateFilter;
                return matchText && matchStatus && matchCarrier && matchDate;
            },

            toggleSortShipmentId() {
                this.sortShipmentAsc = !this.sortShipmentAsc;
                const tbody = this.$refs.shipmentTbody;
                if (!tbody) return;
                const rows = Array.from(tbody.querySelectorAll('tr.shipment-row'));
                rows.sort((a, b) => {
                    const ca = a.dataset.code || '';
                    const cb = b.dataset.code || '';
                    const cmp = ca.localeCompare(cb, undefined, { numeric: true, sensitivity: 'base' });
                    return this.sortShipmentAsc ? cmp : -cmp;
                });
                rows.forEach(r => tbody.appendChild(r));
            },

            calculateFinancials() {
                const weight = parseFloat(this.newShipmentWeight) || 0;
                const carrierId = this.newShipmentCarrierId;
                const dest = this.newShipmentDest;
                const priority = this.newShipmentPriority;
                if (!carrierId || weight <= 0) return;
                let card = this.rateCards.find(r => (r.CarrierId || r.carrierId) == carrierId && (dest && (r.Zone || r.zone) && (r.Zone || r.zone).toLowerCase().includes(dest.toLowerCase())));
                if (!card) card = this.rateCards.find(r => (r.CarrierId || r.carrierId) == carrierId);
                if (card) {
                    const baseRate = parseFloat(card.BaseRatePerKg || card.baseRatePerKg) || 0;
                    const fuelSurcharge = parseFloat(card.FuelSurchargePercent || card.fuelSurchargePercent) || 0;
                    const handlingFee = parseFloat(card.HandlingFee || card.handlingFee) || 0;
                    const cost = (weight * baseRate) + (weight * baseRate * (fuelSurcharge / 100)) + handlingFee;
                    let multiplier = 1.0, margin = 0.25;
                    if (priority === 'Express') { multiplier = 1.35; margin = 0.35; }
                    else if (priority === 'Critical') { multiplier = 1.75; margin = 0.50; }
                    this.newShipmentEstimatedCost = cost.toFixed(2);
                    this.newShipmentShippingFee = (cost * multiplier * (1 + margin)).toFixed(2);
                }
            },

            openCreate() {
                this.isEditing = false;
                this.editingShipmentId = '';
                this.editingShipmentCode = '';
                this.editingShipmentStatus = '';
                this.showCreatePanel = true;
                this.newShipmentWeight = 0;
                this.newShipmentCarrierId = '';
                this.newShipmentDest = '';
                this.newShipmentPriority = 'Standard';
                this.newShipmentShippingFee = 0;
                this.newShipmentEstimatedCost = 0;
                this.$nextTick(() => {
                    const form = this.$refs.shipmentDrawerForm;
                    if (!form) return;
                    const originInput = form.querySelector('input[name="Origin"]');
                    if (originInput) originInput.value = '';
                    const destInput = form.querySelector('input[name="Destination"]');
                    if (destInput) destInput.value = '';
                    const volInput = form.querySelector('input[name="Volume"]');
                    if (volInput) volInput.value = '';
                    const notes = form.querySelector('textarea[name="Notes"]');
                    if (notes) notes.value = '';
                    ['CargoType', 'WarehouseId', 'CarrierId'].forEach((n) => {
                        const sel = form.querySelector(`select[name="${n}"]`);
                        if (sel) sel.selectedIndex = 0;
                    });
                    const dateInput = form.querySelector('input[name="ScheduledDate"]');
                    if (dateInput) dateInput.value = '';
                    form.querySelectorAll('input[name="Handling"]').forEach((cb) => { cb.checked = false; });
                });
            },

            openViewFromRow(row) {
                if (!row || !row.dataset) return;
                this.selectedShipment = {
                    shipmentId: row.dataset.id,
                    shipmentCode: row.dataset.code,
                    origin: row.dataset.origin,
                    destination: row.dataset.destination,
                    carrierName: row.dataset.carrier,
                    carrierId: row.dataset.carrierId,
                    cargoType: row.dataset.cargo,
                    weight: row.dataset.weight,
                    status: row.dataset.status,
                    priority: row.dataset.priority,
                    warehouseName: row.dataset.warehouse,
                    warehouseId: row.dataset.warehouseId,
                    scheduledDate: row.dataset.scheduled,
                    shippingFee: parseFloat(row.dataset.fee) || 0,
                    estimatedCost: parseFloat(row.dataset.cost) || 0
                };
                this.showViewPanel = true;
            },

            async submitCreate() {
                const form = this.$refs.shipmentDrawerForm;
                if (!form) { window.showToast?.('Form not found. Please refresh the page.', 'error'); return; }
                const fd = new FormData(form);

                // Collect all values explicitly
                const origin = (fd.get('Origin') || '').trim();
                const dest = (fd.get('Destination') || '').trim();
                const cargo = (fd.get('CargoType') || '').trim();
                const weightStr = (fd.get('Weight') || '').trim();
                const weight = parseFloat(weightStr);
                const carrierId = parseInt(fd.get('CarrierId') || '0', 10);
                const warehouseId = parseInt(fd.get('WarehouseId') || '0', 10);
                const dateRaw = (fd.get('ScheduledDate') || '').trim();
                const volume = (fd.get('Volume') || '').trim();
                const notes = (fd.get('Notes') || '').trim();
                const priority = this.newShipmentPriority || 'Standard';
                const shippingFee = parseFloat(this.newShipmentShippingFee) || 0;
                const estimatedCost = parseFloat(this.newShipmentEstimatedCost) || 0;

                // Collect handling checkboxes
                const handlingVals = fd.getAll('Handling');

                // Client-side validation
                if (!origin) { window.showToast?.('Origin is required.', 'error'); return; }
                if (!dest) { window.showToast?.('Destination is required.', 'error'); return; }
                if (!cargo) { window.showToast?.('Cargo type is required.', 'error'); return; }
                if (!(weight > 0)) { window.showToast?.('Weight must be greater than 0.', 'error'); return; }
                if (!carrierId) { window.showToast?.('Please select a carrier.', 'error'); return; }
                if (!dateRaw) { window.showToast?.('Scheduled date is required.', 'error'); return; }

                const token = this.getAntiForgeryToken();
                const isEditing = this.isEditing;
                const editingId = parseInt(this.editingShipmentId || '0', 10);

                // Build payload as JSON - avoids ALL culture/model-binding issues
                const payload = {
                    Origin: origin,
                    Destination: dest,
                    CargoType: cargo,
                    Weight: weight,
                    Volume: volume ? parseFloat(volume) : null,
                    Priority: priority,
                    ScheduledDate: dateRaw,
                    CarrierId: carrierId,
                    WarehouseId: warehouseId || null,
                    ShippingFee: shippingFee,
                    EstimatedCost: estimatedCost,
                    Handling: handlingVals,
                    Notes: notes || null
                };
                if (isEditing) payload.ShipmentId = editingId;

                console.log('=== SUBMIT CREATE (JSON) ===', payload);

                const url = isEditing ? '@Url.Action("Update", "Shipment")' : '@Url.Action("Create", "Shipment")';
                try {
                    const res = await fetch(url, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                            '__RequestVerificationToken': token
                        },
                        body: JSON.stringify(payload)
                    });
                    const text = await res.text();
                    console.log('Response status:', res.status, 'body:', text);
                    let data;
                    try { data = JSON.parse(text); }
                    catch { window.showToast?.('Server error. Please refresh and try again.', 'error'); return; }
                    const isSuccess = data.success === true || data.Success === true;
                    const msg = data.message || data.Message || 'Request failed';
                    if (isSuccess) {
                        window.showToast?.(msg);
                        this.showCreatePanel = false;
                        setTimeout(() => {
                            window.location.href = window.location.pathname + '?t=' + Date.now();
                        }, 800);
                    } else {
                        window.showToast?.(msg, 'error');
                    }
                } catch (err) {
                    window.showToast?.('Network error. Try again.', 'error');
                }
            },

            clearFilters() {
                this.searchText = '';
                this.statusFilter = '';
                this.statusFilterGroup = '';
                this.carrierFilter = '';
                this.dateFilter = '';
            },

            async approveShipment(id) {
                const sid = parseInt(id, 10);
                if (!sid) {
                    window.showToast?.('Invalid shipment.', 'error');
                    return;
                }
                const token = this.getAntiForgeryToken();
                const fd = new FormData();
                fd.append('shipmentId', String(sid));
                if (token) fd.append('__RequestVerificationToken', token);
                try {
                    const res = await fetch('@Url.Action("Approve", "Shipment")', {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin',
                        headers: this.antiforgeryHeaders()
                    });
                    const text = await res.text();
                    let data;
                    try {
                        data = JSON.parse(text);
                    } catch {
                        window.showToast?.('Server error. Refresh and try again.', 'error');
                        return;
                    }
                    const isSuccess = data.success === true || data.Success === true;
                    const msg = data.message || data.Message || 'Approve failed';
                    if (isSuccess) {
                        window.showToast?.(msg);
                        this.showViewPanel = false;
                        setTimeout(() => location.reload(), 600);
                    } else {
                        window.showToast?.(msg, 'error');
                    }
                } catch {
                    window.showToast?.('Network error.', 'error');
                }
            },

            async cancelShipment(id) {
                const sid = parseInt(id, 10);
                if (!sid) {
                    window.showToast?.('Invalid shipment.', 'error');
                    return;
                }
                const result = await Swal.fire({
                    title: 'Cancel Shipment?',
                    text: 'This action cannot be undone. The shipment will be permanently cancelled.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Cancel It',
                    cancelButtonText: 'Keep Shipment',
                    confirmButtonColor: '#e11d48',
                    cancelButtonColor: '#64748b',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[1.5rem] shadow-2xl',
                        title: 'text-slate-900 font-bold',
                        htmlContainer: 'text-slate-500 text-sm',
                        confirmButton: 'rounded-xl px-6 py-2.5 font-bold text-sm',
                        cancelButton: 'rounded-xl px-6 py-2.5 font-bold text-sm'
                    }
                });
                if (!result.isConfirmed) return;
                const token = this.getAntiForgeryToken();
                const fd = new FormData();
                fd.append('shipmentId', String(sid));
                if (token) fd.append('__RequestVerificationToken', token);
                try {
                    const res = await fetch('@Url.Action("Cancel", "Shipment")', {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin',
                        headers: this.antiforgeryHeaders()
                    });
                    const text = await res.text();
                    let data;
                    try {
                        data = JSON.parse(text);
                    } catch {
                        Swal.fire({ title: 'Error', text: 'Server error. Refresh and try again.', icon: 'error', confirmButtonColor: '#0ea5e9' });
                        return;
                    }
                    const isSuccess = data.success === true || data.Success === true;
                    const msg = data.message || data.Message || 'Cancel failed';
                    if (isSuccess) {
                        Swal.fire({ title: 'Success!', text: msg, icon: 'success', confirmButtonColor: '#0ea5e9', customClass: { popup: 'rounded-[1.5rem]', confirmButton: 'rounded-xl px-6 py-2.5 font-bold text-sm' } });
                        this.showViewPanel = false;
                        setTimeout(() => location.reload(), 1200);
                    } else {
                        Swal.fire({ title: 'Error', text: msg, icon: 'error', confirmButtonColor: '#0ea5e9', customClass: { popup: 'rounded-[1.5rem]', confirmButton: 'rounded-xl px-6 py-2.5 font-bold text-sm' } });
                    }
                } catch {
                    Swal.fire({ title: 'Error', text: 'Network error.', icon: 'error', confirmButtonColor: '#0ea5e9' });
                }
            },

            editShipment() {
                const s = this.selectedShipment;
                this.showViewPanel = false;
                this.isEditing = true;
                this.editingShipmentId = s.shipmentId ? String(s.shipmentId) : '';
                this.editingShipmentCode = s.shipmentCode || '';
                this.editingShipmentStatus = s.status || '';
                this.$nextTick(() => {
                    this.newShipmentDest = s.destination || '';
                    this.newShipmentWeight = s.weight || 0;
                    this.newShipmentCarrierId = s.carrierId != null && s.carrierId !== '' ? String(s.carrierId) : '';
                    this.newShipmentPriority = s.priority || 'Standard';
                    this.newShipmentShippingFee = s.shippingFee || 0;
                    this.newShipmentEstimatedCost = s.estimatedCost || 0;
                    this.showCreatePanel = true;

                    this.$nextTick(() => {
                        const panel = this.$refs.shipmentDrawerForm;
                        if (panel) {
                            const originInput = panel.querySelector('input[name="Origin"]');
                            if (originInput) originInput.value = s.origin || '';
                            const cargoSelect = panel.querySelector('select[name="CargoType"]');
                            if (cargoSelect) cargoSelect.value = s.cargoType || '';
                            const dateInput = panel.querySelector('input[name="ScheduledDate"]');
                            if (dateInput) dateInput.value = s.scheduledDate || '';
                            const warehouseSelect = panel.querySelector('select[name="WarehouseId"]');
                            if (warehouseSelect) warehouseSelect.value = s.warehouseId || '';
                            panel.querySelectorAll('input[name="Handling"]').forEach((cb) => { cb.checked = false; });
                        }
                    });
                });
            }
        };
    }
</script>
