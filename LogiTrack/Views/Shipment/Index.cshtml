@model LogiTrack.Models.ShipmentPlanningViewModel
@{
    ViewData["Title"] = "Shipment Planning";
    ViewData["ActiveNav"] = "Shipment";
    Layout = null;
    var currentRole = (ViewBag.UserRole?.ToString() ?? string.Empty).Trim();
    var canCancelShipment = currentRole.Equals("Admin", StringComparison.OrdinalIgnoreCase)
        || currentRole.Equals("Super Admin", StringComparison.OrdinalIgnoreCase)
        || currentRole.Equals("Manager", StringComparison.OrdinalIgnoreCase)
        || currentRole.Equals("Logistics Manager", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LogiTrack - Shipment Planning</title>
    <link rel="icon" type="image/png" href="@Url.Content("~/Images/Logo.png")" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .font-display { font-family: 'Barlow Condensed', sans-serif; }
        .sidebar-overlay { transition: opacity 0.3s ease; }
        .sidebar-drawer { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-900" x-data="{ sidebarOpen: false }">
<div class="min-h-screen flex flex-col">

    <!-- Top Header Bar with Burger Menu -->
    <header class="sticky top-0 z-30 bg-white/80 backdrop-blur-md border-b border-slate-200 px-4 py-3 flex items-center gap-4">
        <button type="button" @@click="sidebarOpen = true" id="shipment-burger-btn"
                class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-slate-900 text-white hover:bg-slate-700 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500/40">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg overflow-hidden bg-slate-100 border border-slate-200 flex items-center justify-center">
                <img src="@Url.Content("~/Images/Logo.png")" alt="LogiTrack" class="object-contain w-full h-full" />
            </div>
            <div>
                <h1 class="font-display text-lg font-bold leading-tight text-slate-900">@ViewBag.UserRole</h1>
                <p class="text-xs text-slate-500 leading-tight">Welcome, <span class="font-semibold text-slate-700">@ViewBag.UserFullName</span></p>
            </div>
        </div>
    </header>

    <!-- Sidebar Overlay -->
    <div x-show="sidebarOpen"
         x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         @@click="sidebarOpen = false"
         class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm"
         style="display: none;"></div>

    <!-- Sidebar Drawer -->
    <aside x-show="sidebarOpen"
           x-transition:enter="transition ease-out duration-300" x-transition:enter-start="-translate-x-full" x-transition:enter-end="translate-x-0"
           x-transition:leave="transition ease-in duration-200" x-transition:leave-start="translate-x-0" x-transition:leave-end="-translate-x-full"
           class="fixed top-0 left-0 z-50 h-full w-72 bg-slate-900 text-slate-100 p-6 overflow-y-auto shadow-2xl"
           style="display: none;" id="shipment-sidebar">

        <!-- Close button -->
        <button type="button" @@click="sidebarOpen = false"
                class="absolute top-4 right-4 w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 text-slate-300 hover:text-white flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>

        <div class="mb-8">
            <div class="w-20 h-20 rounded-2xl overflow-hidden bg-white/10 border border-slate-700 flex items-center justify-center mb-4">
                <img src="@Url.Content("~/Images/Logo.png")" alt="LogiTrack" class="object-contain w-full h-full" />
            </div>
            <h1 class="font-display text-3xl font-bold">@ViewBag.UserRole</h1>
            <p class="text-sm text-slate-300">Welcome, <span class="font-bold text-white">@ViewBag.UserFullName</span></p>
        </div>

        <nav class="space-y-2 text-sm">
            @{
                var assignedModules = (List<string>)ViewBag.AssignedModules;
            }
            @if (assignedModules.Count == 0)
            {
                <p class="px-3 py-2 text-slate-300 text-xs">No modules assigned.</p>
            }
            else
            {
                @foreach (var module in assignedModules)
                {
                    var target = "#";
                    var isActive = false;
                    if (module.Equals("Dashboard", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "Client") ?? "#";
                    }
                    else if (module.Equals("Shipments", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "Shipment") ?? "#";
                        isActive = true;
                    }
                    else if (module.Equals("Routes", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "Route") ?? "#";
                    }
                    else if (module.Equals("Warehouses", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "Warehouse") ?? "#";
                    }
                    else if (module.Equals("Tracking", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "Tracking") ?? "#";
                    }
                    else if (module.Equals("Freight Costs", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "FreightCost") ?? "#";
                    }
                    else if (module.Equals("Audit Logs", StringComparison.OrdinalIgnoreCase))
                    {
                        target = Url.Action("Index", "Client") + "#logs";
                    }
                    <a href="@target" class="flex items-center gap-2 px-3 py-2 rounded-lg @(isActive ? "bg-slate-800 font-semibold" : "hover:bg-slate-800") transition">
                        @if (module.Equals("Dashboard", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h7v5H4zM13 6h7v5h-7zM4 13h7v5H4zM13 13h7v5h-7z" /></svg>
                        }
                        else if (module.Equals("Shipments", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V7a2 2 0 00-2-2h-3m5 8l-2.5 5H6.5L4 13m16 0H4m16 0l-3-6H7l-3 6" /></svg>
                        }
                        else if (module.Equals("Routes", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A2 2 0 013 15.382V6.618a2 2 0 011.105-1.789L9 2m0 18l6-3m-6 3V2m6 15l5.447-2.724A2 2 0 0021 12.382V3.618a2 2 0 00-1.105-1.789L15 2m0 15V2m0 0L9 5" /></svg>
                        }
                        else if (module.Equals("Warehouses", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-violet-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M5 21V7l7-4 7 4v14M9 11h6m-6 4h6" /></svg>
                        }
                        else if (module.Equals("Tracking", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A2 2 0 013 15.382V6.618a2 2 0 011.105-1.789L9 2m0 18l6-3m-6 3V2m6 15l5.447-2.724A2 2 0 0021 12.382V3.618a2 2 0 00-1.105-1.789L15 2m0 15V2m0 0L9 5" /></svg>
                        }
                        else if (module.Equals("Freight Costs", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        }
                        else if (module.Equals("Reports", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-cyan-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-6m3 6V7m3 10v-4M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                        }
                        else if (module.Equals("System Settings", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-1.14 1.603-1.14 1.902 0a1 1 0 001.516.59c.996-.63 2.306.68 1.676 1.676a1 1 0 00.59 1.516c1.14.3 1.14 1.603 0 1.902a1 1 0 00-.59 1.516c.63.996-.68 2.306-1.676 1.676a1 1 0 00-1.516.59c-.3 1.14-1.603 1.14-1.902 0a1 1 0 00-1.516-.59c-.996.63-2.306-.68-1.676-1.676a1 1 0 00-.59-1.516c-1.14-.3-1.14-1.603 0-1.902a1 1 0 00.59-1.516c-.63-.996.68-2.306 1.676-1.676a1 1 0 001.516-.59zM12 10a2 2 0 100 4 2 2 0 000-4z" /></svg>
                        }
                        else if (module.Equals("Audit Logs", StringComparison.OrdinalIgnoreCase))
                        {
                            <svg class="w-4 h-4 text-lime-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-6m3 6V7m3 10v-4M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                        }
                        else
                        {
                            <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
                        }
                        <span>@module</span>
                    </a>
                }
            }
        </nav>

        <div class="mt-10 pt-6 border-t border-slate-700">
            <a href="@Url.Action("Logout", "Account")" class="inline-flex w-full items-center justify-center px-4 py-2 rounded-lg bg-sky-600 text-white font-semibold hover:bg-sky-500 transition">
                Logout
            </a>
        </div>
    </aside>

    <main class="flex-1">
<div x-data="{
        showCreatePanel: false,
        showEditPanel: false,
        searchText: '',
        statusFilter: '',
        carrierFilter: '',
        dateFilter: '',
        rowMatches(row) {
            const text = (row.dataset.search || '').toLowerCase();
            const status = (row.dataset.status || '').toLowerCase();
            const carrier = (row.dataset.carrier || '').toLowerCase();
            const date = row.dataset.date || '';
            const search = this.searchText.toLowerCase();

            const searchOk = !search || text.includes(search);
            const statusOk = !this.statusFilter || status === this.statusFilter.toLowerCase();
            const carrierOk = !this.carrierFilter || carrier === this.carrierFilter.toLowerCase();
            const dateOk = !this.dateFilter || date === this.dateFilter;
            return searchOk && statusOk && carrierOk && dateOk;
        },
        openEdit(el) {
            const row = el.closest('tr');
            document.getElementById('editShipmentId').value = row.dataset.editId;
            document.getElementById('editOrigin').value = row.dataset.editOrigin;
            document.getElementById('editDestination').value = row.dataset.editDest;
            document.getElementById('editCargoType').value = row.dataset.editCargo;
            document.getElementById('editWeight').value = row.dataset.editWeight;
            document.getElementById('editScheduledDate').value = row.dataset.editDate;
            document.getElementById('editCarrierId').value = row.dataset.editCarrier;
            document.getElementById('editShipmentCode').textContent = 'Editing ' + row.dataset.editCode;
            this.showEditPanel = true;
        },
        clearFilters() {
            this.searchText = '';
            this.statusFilter = '';
            this.carrierFilter = '';
            this.dateFilter = '';
        }
    }"
     class="space-y-6 p-6 max-w-7xl mx-auto">

    @* ===== PAGE HEADER ===== *@
    <div class="flex items-center justify-between">
        <div>
            <h1 class="font-display text-4xl font-bold text-slate-900">Shipment Planning</h1>
            <p class="text-sm text-slate-600 mt-1">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</p>
        </div>
        <div class="flex items-center gap-3">
            <button class="flex items-center gap-2 bg-slate-100 hover:bg-slate-200 border border-slate-300 text-slate-700 text-sm px-4 py-2.5 rounded-lg transition-all font-semibold">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" /></svg>
                Export
            </button>
            <button @@click="showCreatePanel = true"
                    class="flex items-center gap-2 bg-sky-600 hover:bg-sky-500 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-all hover:shadow-lg hover:shadow-sky-500/20">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" /></svg>
                New Shipment
            </button>
        </div>
    </div>

    @* ===== KPI STRIP ===== *@
    <div class="grid grid-cols-4 gap-4">
        @{
            var kpis = new[] {
                new { Label="Total Today", Value=Model.TotalToday.ToString(), Delta="Live", Up=true, Icon="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2", GradientFrom="from-blue-50", GradientTo="to-blue-100/50", AccentColor="text-blue-600" },
                new { Label="Pending Approval", Value=Model.PendingApproval.ToString(), Delta="Queue", Up=false, Icon="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", GradientFrom="from-orange-50", GradientTo="to-orange-100/50", AccentColor="text-orange-600" },
                new { Label="In Transit", Value=Model.InTransit.ToString(), Delta="Active", Up=true, Icon="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1", GradientFrom="from-cyan-50", GradientTo="to-cyan-100/50", AccentColor="text-cyan-600" },
                new { Label="Completed", Value=Model.Completed.ToString(), Delta="Delivered", Up=true, Icon="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", GradientFrom="from-emerald-50", GradientTo="to-emerald-100/50", AccentColor="text-emerald-600" },
            }.ToList();
        }
        @foreach (var kpi in kpis)
        {
            <div class="bg-gradient-to-br @kpi.GradientFrom @kpi.GradientTo border border-slate-200 rounded-2xl p-6 hover:shadow-md transition-all hover:scale-[1.01]">
                <div class="flex items-start justify-between mb-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">@kpi.Label</p>
                    <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="@kpi.Icon" />
                    </svg>
                </div>
                <p class="text-3xl font-bold @kpi.AccentColor">@kpi.Value</p>
                <div class="flex items-center gap-1.5 mt-3">
                    @if (kpi.Up)
                    {
                        <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 15l7-7 7 7" /></svg>
                        <span class="text-xs text-emerald-600">@kpi.Delta</span>
                    }
                    else
                    {
                        <svg class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M19 9l-7 7-7-7" /></svg>
                        <span class="text-xs text-red-600">@kpi.Delta</span>
                    }
                </div>
            </div>
        }
    </div>

    @* ===== FILTERS BAR ===== *@
    <div class="flex items-center gap-3 flex-wrap bg-white border border-slate-200 rounded-lg p-4">
        <div class="relative flex-1 min-w-64">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
            <input type="text" placeholder="Search by ID, carrier, destination…"
                   x-model="searchText"
                   class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-900 placeholder:text-slate-500 rounded-lg pl-10 pr-4 py-2 text-sm outline-none transition-all" />
        </div>
        <select x-model="statusFilter" class="bg-slate-50 border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm outline-none focus:border-sky-500">
            <option value="">All Status</option>
            <option>Pending</option>
            <option>In Transit</option>
            <option>Delivered</option>
            <option>Completed</option>
            <option>Cancelled</option>
        </select>
        <select x-model="carrierFilter" class="bg-slate-50 border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm outline-none focus:border-sky-500">
            <option value="">All Carriers</option>
            @foreach (var carrier in Model.Carriers)
            {
                <option>@carrier.Name</option>
            }
        </select>
        <input type="date" x-model="dateFilter" class="bg-slate-50 border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm outline-none focus:border-sky-500" />
        <button type="button" @@click="clearFilters()" class="text-sm text-sky-600 hover:text-sky-700 transition-colors font-semibold">Clear filters</button>
    </div>

    @* ===== SHIPMENT TABLE ===== *@
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">
                            <div class="flex items-center gap-1.5 cursor-pointer hover:text-sky-600 transition-colors">Shipment ID <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 9l4-4 4 4m0 6l-4 4-4-4" /></div>
                        </th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Route</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Carrier</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Cargo Type</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Weight</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Priority</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Status</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Sched. Date</th>
                        <th class="px-6 py-4 text-left text-xs text-slate-500 font-semibold">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    @if (Model.Shipments.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="px-6 py-8 text-center text-slate-500 text-sm">No shipment records found.</td>
                        </tr>
                    }
                    @foreach (var s in Model.Shipments)
                    {
                        var priorityClass = s.Priority == "Critical"
                            ? "text-red-600 bg-red-50 border-red-200"
                            : s.Priority == "Express"
                                ? "text-orange-600 bg-orange-50 border-orange-200"
                                : "text-slate-600 bg-slate-50 border-slate-200";
                        var statusClass = s.Status == "In Transit"
                            ? "text-cyan-600 bg-cyan-50 border-cyan-200"
                            : (s.Status == "Delivered" || s.Status == "Completed")
                                ? "text-emerald-600 bg-emerald-50 border-emerald-200"
                                : s.Status == "Cancelled"
                                    ? "text-red-600 bg-red-50 border-red-200"
                                    : s.Status == "Archived"
                                        ? "text-slate-500 bg-slate-100 border-slate-300"
                                        : "text-orange-600 bg-orange-50 border-orange-200";
                        <tr x-show="rowMatches($el)"
                            data-search="@($"{s.ShipmentCode} {s.Origin} {s.Destination} {s.CarrierName} {s.CargoType}")"
                            data-status="@s.Status"
                            data-carrier="@s.CarrierName"
                            data-date="@s.ScheduledDate.ToString("yyyy-MM-dd")"
                            data-edit-id="@s.ShipmentId"
                            data-edit-code="@s.ShipmentCode"
                            data-edit-origin="@s.Origin"
                            data-edit-dest="@s.Destination"
                            data-edit-cargo="@s.CargoType"
                            data-edit-weight="@s.Weight"
                            data-edit-date="@s.ScheduledDate.ToString("yyyy-MM-dd")"
                            data-edit-carrier="@s.CarrierId"
                            class="hover:bg-slate-50 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-sm text-sky-600 hover:text-sky-700 cursor-pointer font-semibold">@s.ShipmentCode</span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2 text-sm text-slate-700">
                                    <span>@s.Origin</span>
                                    <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7l7 7-7 7" /></svg>
                                    <span>@s.Destination</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-700">@s.CarrierName</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@s.CargoType</td>
                            <td class="px-6 py-4 text-sm text-slate-700">@($"{s.Weight:0.##} kg")</td>
                            <td class="px-6 py-4">
                                <span class="text-xs font-semibold px-3 py-1.5 rounded-full border @priorityClass">@s.Priority</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs font-semibold px-3 py-1.5 rounded-full border @statusClass">@s.Status</span>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600">@s.ScheduledDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    @if (string.Equals(s.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button class="text-xs bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-200 px-3 py-1.5 rounded-lg transition-colors font-semibold"
                                                onclick="approveShipment(@s.ShipmentId)">
                                            Approve
                                        </button>
                                    }
                                    <button class="text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 py-1.5 rounded-lg transition-colors font-semibold"
                                            @@click="openEdit($el)">Edit</button>
                                    @if (canCancelShipment &&
                                         !string.Equals(s.Status, "Cancelled", StringComparison.OrdinalIgnoreCase) &&
                                         !string.Equals(s.Status, "Delivered", StringComparison.OrdinalIgnoreCase) &&
                                         !string.Equals(s.Status, "Completed", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button class="text-xs bg-red-50 hover:bg-red-100 text-red-700 border border-red-200 px-3 py-1.5 rounded-lg transition-colors font-semibold"
                                                onclick="cancelShipment(@s.ShipmentId)">Cancel</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination *@
        <div class="px-6 py-4 border-t border-slate-200 flex items-center justify-between bg-slate-50">
            <span class="text-xs text-slate-600">Showing @Model.Shipments.Count shipment(s)</span>
            <div class="flex items-center gap-1">
                <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-200 hover:bg-slate-300 text-slate-700 transition-colors text-xs font-semibold">‹</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-sky-600 text-white text-xs font-bold">1</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-200 hover:bg-slate-300 text-slate-700 transition-colors text-xs">2</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-200 hover:bg-slate-300 text-slate-700 transition-colors text-xs">3</button>
                <span class="text-slate-500 px-1 text-xs">…</span>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-200 hover:bg-slate-300 text-slate-700 transition-colors text-xs">26</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-200 hover:bg-slate-300 text-slate-700 transition-colors text-xs">›</button>
            </div>
        </div>
