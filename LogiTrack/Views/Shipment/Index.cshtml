@model LogiTrack.Models.ShipmentPlanningViewModel
@{
    ViewData["Title"] = "Shipment Planning";
    ViewData["ActiveNav"] = "shipment";
    Layout = "_ModuleLayout";
    var currentRole = (ViewBag.UserRole?.ToString() ?? string.Empty).Trim();
    var isManagerOrAdmin = currentRole.Equals("Admin", StringComparison.OrdinalIgnoreCase)
        || currentRole.Equals("Manager", StringComparison.OrdinalIgnoreCase);
}

<div x-data="shipmentModule()" class="p-6 lg:p-8 space-y-6 min-h-screen bg-[#F5F7FA]">

    @* PAGE HEADER (matches shipment planning dashboard spec) *@
    <div class="flex flex-wrap items-center justify-between gap-6">
        <div>
            <h1 class="font-display text-3xl sm:text-4xl font-black text-slate-900 uppercase tracking-tight">Shipment planning</h1>
            <p class="text-sm text-slate-500 font-medium mt-1">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</p>
        </div>
        <div class="flex items-center gap-3">
            <form action="@Url.Action("Export", "Shipment")" method="post" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-5 py-2.5 border border-slate-300 bg-white text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2 shadow-sm">
                    <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Export CSV
                </button>
            </form>
            @if (isManagerOrAdmin)
            {
            <button type="button" @@click="openCreate()" class="px-5 py-2.5 bg-[#0088CC] hover:bg-[#0077b3] text-white text-sm font-semibold rounded-lg transition-colors flex items-center gap-2 shadow-md shadow-[#0088CC]/25">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                New Shipment
            </button>
            }
        </div>
    </div>

    @* KPI CARDS (click to filter table) *@
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
        <button type="button" @@click="applyKpiFilter('all')" class="rounded-xl border border-slate-200/80 bg-sky-50/60 p-5 shadow-sm relative overflow-hidden text-left cursor-pointer hover:shadow-md hover:border-sky-300/80 transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-[#0088CC]">
            <svg class="w-5 h-5 text-sky-400 absolute top-4 right-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest pr-8">Total Today</p>
            <p class="mt-2 text-4xl font-bold text-[#0088CC] tabular-nums" x-text="kpis.totalToday">@Model.TotalToday</p>
            <p class="mt-3 text-xs font-semibold text-emerald-600 flex items-center gap-1"><span class="text-emerald-500">↑</span> Live</p>
        </button>
        <button type="button" @@click="applyKpiFilter('Pending')" class="rounded-xl border border-orange-100 bg-orange-50/50 p-5 shadow-sm relative overflow-hidden text-left cursor-pointer hover:shadow-md hover:border-orange-200 transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-400">
            <svg class="w-5 h-5 text-orange-300 absolute top-4 right-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest pr-8">Pending</p>
            <p class="mt-2 text-4xl font-bold text-orange-500 tabular-nums" x-text="kpis.pending">@Model.PendingApproval</p>
            <p class="mt-3 text-xs font-semibold text-red-500 flex items-center gap-1"><span>↓</span> Queue</p>
        </button>
        <button type="button" @@click="applyKpiFilter('In Transit')" class="rounded-xl border border-teal-100 bg-teal-50/50 p-5 shadow-sm relative overflow-hidden text-left cursor-pointer hover:shadow-md hover:border-teal-200 transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-500">
            <svg class="w-5 h-5 text-teal-500 absolute top-4 right-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" /></svg>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest pr-8">In Transit</p>
            <p class="mt-2 text-4xl font-bold text-teal-600 tabular-nums" x-text="kpis.inTransit">@Model.InTransit</p>
            <p class="mt-3 text-xs font-semibold text-emerald-600 flex items-center gap-1"><span class="text-emerald-500">↑</span> Active</p>
        </button>
        <button type="button" @@click="applyKpiFilter('Completed')" class="rounded-xl border border-emerald-100 bg-emerald-50/50 p-5 shadow-sm relative overflow-hidden text-left cursor-pointer hover:shadow-md hover:border-emerald-200 transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500">
            <svg class="w-5 h-5 text-emerald-400 absolute top-4 right-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest pr-8">Completed</p>
            <p class="mt-2 text-4xl font-bold text-emerald-600 tabular-nums" x-text="kpis.completed">@Model.Completed</p>
            <p class="mt-3 text-xs font-semibold text-emerald-600 flex items-center gap-1"><span class="text-emerald-500">↑</span> Delivered</p>
        </button>
    </div>

    @* FILTER BAR *@
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-4 flex flex-wrap items-center gap-3">
        <div class="relative flex-1 min-w-[220px]">
            <input type="text" x-model="searchText" placeholder="Search by ID, carrier, destination..." class="w-full bg-white border border-slate-200 rounded-lg pl-10 pr-3 py-2.5 text-sm text-slate-800 placeholder:text-slate-400 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/30" />
            <svg class="w-4 h-4 text-slate-400 absolute left-3 top-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </div>
        <div class="relative">
            <select x-model="statusFilter" @@change="statusFilterGroup = ''" class="appearance-none bg-white border border-slate-200 rounded-lg pl-3 pr-9 py-2.5 text-sm text-slate-700 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/30 min-w-[140px]">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="In Transit">In Transit</option>
                <option value="Delivered">Delivered</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
            <svg class="w-4 h-4 text-slate-400 absolute right-2.5 top-3 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </div>
        <div class="relative">
            <select x-model="carrierFilter" class="appearance-none bg-white border border-slate-200 rounded-lg pl-3 pr-9 py-2.5 text-sm text-slate-700 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/30 min-w-[150px]">
                <option value="">All Carriers</option>
                <template x-for="c in carriers" :key="c.CarrierId || c.carrierId">
                    <option :value="c.Name || c.name" x-text="c.Name || c.name"></option>
                </template>
            </select>
            <svg class="w-4 h-4 text-slate-400 absolute right-2.5 top-3 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </div>
        <div class="relative min-w-[160px]">
            <input type="date" x-model="dateFilter" class="w-full bg-white border border-slate-200 rounded-lg pl-3 pr-3 py-2.5 text-sm text-slate-700 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/30" title="Filter by scheduled date" />
        </div>
        <button type="button" @@click="clearFilters()" class="text-sm font-semibold text-[#0088CC] hover:text-[#0077b3] ml-auto">Clear filters</button>
    </div>

    @* DATA TABLE *@
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="px-6 py-4">
                            <button type="button" @@click="toggleSortShipmentId()" class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-500 uppercase tracking-widest hover:text-[#0088CC] transition-colors">
                                Shipment ID
                                <span class="inline-flex flex-col leading-none text-[#0088CC]">
                                    <svg class="w-3 h-3 -mb-0.5 transition-opacity" :class="sortShipmentAsc ? 'opacity-100' : 'opacity-30'" fill="currentColor" viewBox="0 0 12 12"><path d="M6 2L2 7h8L6 2z" /></svg>
                                    <svg class="w-3 h-3 transition-opacity" :class="!sortShipmentAsc ? 'opacity-100' : 'opacity-30'" fill="currentColor" viewBox="0 0 12 12"><path d="M6 10l4-5H2l4 5z" /></svg>
                                </span>
                            </button>
                        </th>
                        <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Route</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Carrier</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Cargo Type</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Weight</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Status</th>
                        <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-right">Actions</th>
                    </tr>
                </thead>
                <tbody x-ref="shipmentTbody" class="divide-y divide-slate-100">
                    @foreach (var s in Model.Shipments)
                    {
                        <tr class="hover:bg-slate-50/80 transition-colors shipment-row"
                            data-id="@s.ShipmentId" data-code="@s.ShipmentCode" data-origin="@s.Origin"
                            data-destination="@s.Destination" data-carrier="@s.CarrierName" data-carrier-id="@s.CarrierId"
                            data-cargo="@s.CargoType" data-weight="@s.Weight" data-status="@s.Status"
                            data-priority="@s.Priority" data-warehouse="@s.WarehouseName" data-warehouse-id="@s.WarehouseId"
                            data-scheduled="@s.ScheduledDate.ToString("yyyy-MM-dd")" data-fee="@s.ShippingFee"
                            data-cost="@s.EstimatedCost"
                            x-show="rowMatches($el)">
                            <td class="px-6 py-4">
                                <button type="button" @@click="openViewFromRow($el.closest('tr'))" class="text-left font-bold text-[#0088CC] hover:text-[#0077b3] hover:underline text-sm tracking-tight">
                                    @s.ShipmentCode
                                </button>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm font-semibold text-slate-700">@s.Origin</span>
                                <span class="mx-1.5 text-slate-400 font-medium">→</span>
                                <span class="text-sm font-semibold text-slate-700">@s.Destination</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm font-semibold text-slate-700">@s.CarrierName</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-sm text-slate-600">@s.CargoType</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-sm font-bold text-slate-900 tabular-nums">@((s.Weight % 1 == 0) ? ((int)s.Weight).ToString() : s.Weight.ToString("0.##")) kg</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                @{
                                    var statusClass = s.Status switch {
                                        "Pending" => "bg-orange-50 text-orange-600 border-orange-100",
                                        "In Transit" => "bg-sky-50 text-teal-700 border-sky-100",
                                        "Delivered" or "Completed" => "bg-emerald-50 text-emerald-700 border-emerald-100",
                                        "Cancelled" => "bg-rose-50 text-rose-600 border-rose-100",
                                        "Received at Warehouse" => "bg-teal-50 text-teal-700 border-teal-100",
                                        _ => "bg-slate-50 text-slate-600 border-slate-100"
                                    };
                                }
                                <span class="text-[10px] font-bold px-3 py-1 rounded-full border @statusClass">@s.Status</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button type="button" @@click="openViewFromRow($event.currentTarget.closest('tr'))" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-sky-100 bg-sky-50 text-[#0088CC] text-xs font-semibold hover:bg-[#0088CC] hover:text-white hover:border-[#0088CC] transition-colors shadow-sm">
                                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                    View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-sm text-slate-500 px-1">
        Showing @Model.Shipments.Count shipment(s)
    </div>

    @* Drawers teleported to body so fixed + scroll are not broken by layout/flex/transform ancestors. Single h-[100dvh] overflow-y-auto column scrolls reliably. *@
    <template x-teleport="body">
    <div x-show="showCreatePanel" x-cloak class="fixed inset-0 z-[100]" style="display: none;">
        <div class="absolute inset-0 bg-slate-900/20 backdrop-blur-sm transition-opacity" @@click="showCreatePanel = false"></div>
        <div
            class="fixed top-0 right-0 z-[101] flex h-[100dvh] max-h-[100svh] w-full max-w-[500px] flex-col overflow-y-auto overflow-x-hidden overscroll-y-contain bg-white shadow-2xl border-l border-slate-200/80 [-webkit-overflow-scrolling:touch]"
            x-transition:enter="transform transition ease-out duration-300"
            x-transition:enter-start="translate-x-full"
            x-transition:enter-end="translate-x-0"
            x-transition:leave="transform transition ease-in duration-200"
            x-transition:leave-start="translate-x-0"
            x-transition:leave-end="translate-x-full">
            <form x-ref="shipmentDrawerForm" @@submit.prevent class="flex w-full flex-col">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Priority" x-model="newShipmentPriority" />
                    <input type="hidden" name="ShipmentId" x-bind:disabled="!isEditing" x-model="editingShipmentId" />
                    <input type="hidden" name="ShippingFee" x-model="newShipmentShippingFee" />
                    <input type="hidden" name="EstimatedCost" x-model="newShipmentEstimatedCost" />

                    <div class="flex shrink-0 items-start justify-between gap-4 border-b border-slate-200 bg-white px-10 pb-6 pt-10">
                        <div>
                            <h2 class="font-display text-3xl font-bold text-[#0A192F]" x-text="isEditing ? 'Edit Shipment' : 'New Shipment'"></h2>
                            <p class="text-sm text-slate-500 mt-1" x-text="isEditing ? editingShipmentCode : 'Fill in details to create a shipment plan'"></p>
                        </div>
                        <button type="button" @@click="showCreatePanel = false" class="shrink-0 p-2 rounded-xl text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors" aria-label="Close">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                        </button>
                    </div>

                    <div class="px-10 py-6 space-y-5">
                        
                        <div x-show="isEditing" x-cloak class="mb-2">
                            <p class="text-sm font-bold text-slate-700 mb-1">Current Status</p>
                            <p class="text-lg font-bold uppercase tracking-wide leading-tight" :class="{
                                'text-amber-600': editingShipmentStatus === 'Pending',
                                'text-teal-600': editingShipmentStatus === 'In Transit' || editingShipmentStatus === 'Received at Warehouse',
                                'text-emerald-600': editingShipmentStatus === 'Delivered' || editingShipmentStatus === 'Completed',
                                'text-rose-600': editingShipmentStatus === 'Cancelled',
                                'text-slate-700': editingShipmentStatus !== 'Pending' && editingShipmentStatus !== 'In Transit' && editingShipmentStatus !== 'Received at Warehouse' && editingShipmentStatus !== 'Delivered' && editingShipmentStatus !== 'Completed' && editingShipmentStatus !== 'Cancelled'
                            }" x-text="editingShipmentStatus"></p>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-[#334155] mb-1.5">Origin <span class="text-rose-500">*</span></label>
                                <input type="text" name="Origin" placeholder="e.g. Manila" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25" />
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-[#334155] mb-1.5">Destination <span class="text-rose-500">*</span></label>
                                <input type="text" name="Destination" x-model="newShipmentDest" @@input="calculateFinancials()" placeholder="e.g. Cebu City" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-[#334155] mb-1.5">Cargo Type <span class="text-rose-500">*</span></label>
                            <div class="relative">
                                <select name="CargoType" class="w-full appearance-none rounded-lg border border-slate-200 bg-white px-3 py-2.5 pr-10 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25">
                                    <option value="">Select cargo type...</option>
                                    <option value="Electronics">Electronics</option>
                                    <option value="Dry Goods">Dry Goods</option>
                                    <option value="Perishables">Perishables</option>
                                    <option value="Machinery">Machinery</option>
                                    <option value="Chemicals">Chemicals</option>
                                    <option value="Textiles">Textiles</option>
                                    <option value="Documents">Documents</option>
                                    <option value="Hazardous">Hazardous</option>
                                </select>
                                <svg class="pointer-events-none absolute right-3 top-3 h-4 w-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-[#334155] mb-1.5">Weight (kg) <span class="text-rose-500">*</span></label>
                                <input type="number" name="Weight" x-model="newShipmentWeight" @@input="calculateFinancials()" placeholder="0" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25" />
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-[#334155] mb-1.5">Volume (m³)</label>
                                <input type="number" step="0.01" name="Volume" placeholder="0.00" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-[#334155] mb-1.5">Priority Level <span class="text-rose-500">*</span></label>
                            <div class="grid grid-cols-3 gap-3">
                                <button type="button" @@click="newShipmentPriority = 'Standard'; calculateFinancials()"
                                        class="rounded-lg py-2.5 text-sm font-semibold transition-all"
                                        :class="newShipmentPriority === 'Standard' ? 'border border-[#d97706] bg-[#fffbeb] text-[#d97706]' : 'border border-slate-200 bg-white text-[#334155] hover:bg-slate-50'">Standard</button>
                                <button type="button" @@click="newShipmentPriority = 'Express'; calculateFinancials()"
                                        class="rounded-lg py-2.5 text-sm font-semibold transition-all"
                                        :class="newShipmentPriority === 'Express' ? 'border border-[#d97706] bg-[#fffbeb] text-[#d97706]' : 'border border-slate-200 bg-white text-[#334155] hover:bg-slate-50'">Express</button>
                                <button type="button" @@click="newShipmentPriority = 'Critical'; calculateFinancials()"
                                        class="rounded-lg py-2.5 text-sm font-semibold transition-all"
                                        :class="newShipmentPriority === 'Critical' ? 'border border-[#d97706] bg-[#fffbeb] text-[#d97706]' : 'border border-slate-200 bg-white text-[#334155] hover:bg-slate-50'">Critical</button>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-[#334155] mb-1.5">Scheduled Date <span class="text-rose-500">*</span></label>
                                <input type="date" name="ScheduledDate" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25" />
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-[#334155] mb-1.5">Carrier <span class="text-rose-500">*</span></label>
                                <div class="relative">
                                    <select name="CarrierId" x-model="newShipmentCarrierId" @@change="calculateFinancials()" class="w-full appearance-none rounded-lg border border-slate-200 bg-white px-3 py-2.5 pr-10 text-sm text-slate-900 outline-none focus:border-[#0088CC] focus:ring-1 focus:ring-[#0088CC]/25">
                                        <option value="">Select carrier...</option>
                                        <template x-for="c in carriers" :key="c.CarrierId || c.carrierId">
                                            <option :value="c.CarrierId || c.carrierId" x-text="c.Name || c.name"></option>
                                        </template>
                                    </select>
                                    <svg class="pointer-events-none absolute right-3 top-3 h-4 w-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                                </div>
                            </div>
