@model LogiTrack.Models.ClientDashboardViewModel
@{
    ViewData["Title"] = "Client Dashboard";
    ViewData["ActiveNav"] = "dashboard";
    Layout = "_ModuleLayout";
}

<div class="space-y-6">
            <div class="mb-8">
                <h2 class="font-display text-4xl font-bold uppercase tracking-wide">Dashboard</h2>
                <p class="text-slate-600">Track your shipments and access your assigned modules.</p>
            </div>

            <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-4 mb-6">
                <div class="rounded-2xl bg-white border border-slate-200 p-4 shadow-sm">
                    <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V7a2 2 0 00-2-2h-3m5 8l-2.5 5H6.5L4 13m16 0H4m16 0l-3-6H7l-3 6" /></svg> Total</p>
                    <p class="text-2xl font-bold mt-2">@Model.TotalMyShipments</p>
                </div>
                <div class="rounded-2xl bg-amber-50 border border-amber-100 p-4 shadow-sm">
                    <p class="text-xs text-amber-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> Pending</p>
                    <p class="text-2xl font-bold text-amber-600 mt-2">@Model.MyPendingShipments</p>
                </div>
                <div class="rounded-2xl bg-cyan-50 border border-cyan-100 p-4 shadow-sm">
                    <p class="text-xs text-cyan-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg> In Transit</p>
                    <p class="text-2xl font-bold text-cyan-600 mt-2">@Model.MyInTransitShipments</p>
                </div>
                <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-4 shadow-sm">
                    <p class="text-xs text-emerald-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Delivered</p>
                    <p class="text-2xl font-bold text-emerald-600 mt-2">@Model.MyDeliveredShipments</p>
                </div>
                <div class="rounded-2xl bg-indigo-50 border border-indigo-100 p-4 shadow-sm">
                    <p class="text-xs text-indigo-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> Completed</p>
                    <p class="text-2xl font-bold text-indigo-600 mt-2">@Model.MyCompletedShipments</p>
                </div>
                <div class="rounded-2xl bg-red-50 border border-red-100 p-4 shadow-sm">
                    <p class="text-xs text-red-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg> Cancelled</p>
                    <p class="text-2xl font-bold text-red-600 mt-2">@Model.MyCancelledShipments</p>
                </div>
            </section>

            <section id="modules" class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
                <div class="lg:col-span-2 rounded-2xl bg-white border border-slate-200">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="font-display text-2xl font-bold">Recent My Shipments</h2>
                    </div>
                    <div class="divide-y divide-slate-100">
                        @if (Model.RecentShipments.Count == 0)
                        {
                            <p class="px-6 py-6 text-slate-500">No shipments yet.</p>
                        }
                        else
                        {
                            @foreach (var shipment in Model.RecentShipments)
                            {
                                <div class="px-6 py-4 flex items-center justify-between gap-4">
                                    <div>
                                        <p class="font-semibold text-slate-900">@shipment.ShipmentCode</p>
                                        <p class="text-sm text-slate-500">@shipment.Origin -> @shipment.Destination</p>
                                        <p class="text-xs text-slate-400 mt-1">
                                            Carrier: @(shipment.Carrier?.Name ?? "Unassigned")
                                            • Scheduled: @shipment.ScheduledDate.ToString("yyyy-MM-dd")
                                        </p>
                                    </div>
                                    @{
                                        var statusClass = shipment.Status == "In Transit" ? "text-cyan-600 bg-cyan-50 border border-cyan-200" :
                                            (shipment.Status == "Delivered" || shipment.Status == "Completed") ? "text-emerald-600 bg-emerald-50 border border-emerald-200" :
                                            shipment.Status == "Cancelled" ? "text-red-600 bg-red-50 border border-red-200" :
                                            "text-orange-600 bg-orange-50 border border-orange-200";
                                    }
                                    <span class="px-2 py-1 rounded-full text-xs @statusClass font-semibold">@shipment.Status</span>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="rounded-2xl bg-white border border-slate-200 p-6 lg:col-span-1">
                    <h2 class="font-display text-2xl font-bold mb-4">My Shipment Summary</h2>
                    <div class="grid grid-cols-2 gap-3 text-sm mb-5">
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Total: <span class="font-semibold">@Model.TotalMyShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Pending: <span class="font-semibold">@Model.MyPendingShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">In Transit: <span class="font-semibold">@Model.MyInTransitShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Delivered: <span class="font-semibold">@Model.MyDeliveredShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Completed: <span class="font-semibold">@Model.MyCompletedShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Cancelled: <span class="font-semibold">@Model.MyCancelledShipments</span></div>
                    </div>
                    <h2 class="font-display text-2xl font-bold mb-4">Quick Actions</h2>
                    <div class="space-y-3">
                        @if (Model.AssignedModules.Any(m => m.Equals("Tracking", StringComparison.OrdinalIgnoreCase)))
                        {
                            <a href="@Url.Action("Index","Tracking")" class="block text-center px-4 py-2.5 rounded-lg bg-sky-600 text-white font-semibold hover:bg-sky-500 transition">Track Shipments</a>
                        }
                        @if (Model.AssignedModules.Any(m => m.Equals("Shipments", StringComparison.OrdinalIgnoreCase)))
                        {
                            <a href="@Url.Action("Index","Shipment")" class="block text-center px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 font-semibold hover:bg-slate-100 transition">View Shipment Module</a>
                        }
                    </div>
                </div>
            </section>

            @if (Model.CanViewAuditLogs)
            {
                <section id="logs" class="rounded-2xl bg-white border border-slate-200">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="font-display text-2xl font-bold">Recent Activity Logs</h2>
                    </div>
                    <div class="divide-y divide-slate-100">
                        @if (Model.RecentActivities.Count == 0)
                        {
                            <p class="px-6 py-6 text-slate-500">No recent activities.</p>
                        }
                        else
                        {
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <div class="px-6 py-4">
                                    <div class="flex items-center justify-between gap-4">
                                        <p class="text-sm text-slate-800">@activity.Action</p>
                                        <span class="text-xs text-slate-400">@activity.Timestamp.ToString("MMM dd, hh:mm tt")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </section>
            }
        </main>
@section Scripts {
    <script>
        // Client-specific scripts if any
    </script>
}
