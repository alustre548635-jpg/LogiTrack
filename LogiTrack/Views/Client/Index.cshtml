@model LogiTrack.Models.ClientDashboardViewModel
@{
    ViewData["Title"] = "Client Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LogiTrack - Client Dashboard</title>
    <link rel="icon" type="image/png" href="@Url.Content("~/Images/Logo.png")" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .font-display { font-family: 'Barlow Condensed', sans-serif; }
        .gradient-accent { background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%); }
        .sidebar-overlay { transition: opacity 0.3s ease; }
        .sidebar-drawer { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-900" x-data="{ sidebarOpen: false }">
    <div class="min-h-screen flex flex-col">

        <!-- Top Header Bar with Burger Menu -->
        <header class="sticky top-0 z-30 bg-white/80 backdrop-blur-md border-b border-slate-200 px-4 py-3 flex items-center gap-4">
            <button type="button" @@click="sidebarOpen = true" id="client-burger-btn"
                    class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-slate-900 text-white hover:bg-slate-700 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500/40">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg overflow-hidden bg-slate-100 border border-slate-200 flex items-center justify-center">
                    <img src="@Url.Content("~/Images/Logo.png")" alt="LogiTrack" class="object-contain w-full h-full" />
                </div>
                <div>
                    <h1 class="font-display text-lg font-bold leading-tight text-slate-900">@Model.Role</h1>
                    <p class="text-xs text-slate-500 leading-tight">Welcome, <span class="font-semibold text-slate-700">@Model.FullName</span></p>
                </div>
            </div>
        </header>

        <!-- Sidebar Overlay -->
        <div x-show="sidebarOpen"
             x-transition:enter="sidebar-overlay" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
             x-transition:leave="sidebar-overlay" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
             @@click="sidebarOpen = false"
             class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm"
             style="display: none;"></div>

        <!-- Sidebar Drawer -->
        <aside x-show="sidebarOpen"
               x-transition:enter="sidebar-drawer" x-transition:enter-start="-translate-x-full" x-transition:enter-end="translate-x-0"
               x-transition:leave="sidebar-drawer" x-transition:leave-start="translate-x-0" x-transition:leave-end="-translate-x-full"
               class="fixed top-0 left-0 z-50 h-full w-72 bg-slate-900 text-slate-100 p-6 overflow-y-auto shadow-2xl"
               style="display: none;" id="client-sidebar">

            <!-- Close button -->
            <button type="button" @@click="sidebarOpen = false"
                    class="absolute top-4 right-4 w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 text-slate-300 hover:text-white flex items-center justify-center transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>

            <div class="mb-8">
                <div class="w-20 h-20 rounded-2xl overflow-hidden bg-white/10 border border-slate-700 flex items-center justify-center mb-4">
                    <img src="@Url.Content("~/Images/Logo.png")" alt="LogiTrack" class="object-contain w-full h-full" />
                </div>
                <h1 class="font-display text-3xl font-bold">@Model.Role</h1>
                <p class="text-sm text-slate-300">Welcome, <span class="font-bold text-white">@Model.FullName</span></p>
            </div>

            <nav class="space-y-2 text-sm">
                @if (Model.AssignedModules.Count == 0)
                {
                    <p class="px-3 py-2 text-slate-300 text-xs">No modules assigned.</p>
                }
                else
                {
                    @foreach (var module in Model.AssignedModules)
                    {
                        var target = "#modules";
                        if (module.Equals("Dashboard", StringComparison.OrdinalIgnoreCase))
                        {
                            target = Url.Action("Index", "Client") ?? "#modules";
                        }
                        else if (module.Equals("Shipments", StringComparison.OrdinalIgnoreCase))
                        {
                            target = Url.Action("Index", "Shipment") ?? "#modules";
                        }
                        else if (module.Equals("Routes", StringComparison.OrdinalIgnoreCase))
                        {
                            target = Url.Action("Index", "Route") ?? "#modules";
                        }
                        else if (module.Equals("Warehouses", StringComparison.OrdinalIgnoreCase))
                        {
                            target = Url.Action("Index", "Warehouse") ?? "#modules";
                        }
                        else if (module.Equals("Tracking", StringComparison.OrdinalIgnoreCase))
                        {
                            target = Url.Action("Index", "Tracking") ?? "#modules";
                        }
                        else if (module.Equals("Freight Costs", StringComparison.OrdinalIgnoreCase))
                        {
                            target = Url.Action("Index", "FreightCost") ?? "#modules";
                        }
                        else if (module.Equals("Audit Logs", StringComparison.OrdinalIgnoreCase))
                        {
                            target = "#logs";
                        }
                        <a href="@target" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-slate-800 transition">
                            @if (module.Equals("Dashboard", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h7v5H4zM13 6h7v5h-7zM4 13h7v5H4zM13 13h7v5h-7z" /></svg>
                            }
                            else if (module.Equals("Shipments", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V7a2 2 0 00-2-2h-3m5 8l-2.5 5H6.5L4 13m16 0H4m16 0l-3-6H7l-3 6" /></svg>
                            }
                            else if (module.Equals("Routes", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A2 2 0 013 15.382V6.618a2 2 0 011.105-1.789L9 2m0 18l6-3m-6 3V2m6 15l5.447-2.724A2 2 0 0021 12.382V3.618a2 2 0 00-1.105-1.789L15 2m0 15V2m0 0L9 5" /></svg>
                            }
                            else if (module.Equals("Warehouses", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-violet-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M5 21V7l7-4 7 4v14M9 11h6m-6 4h6" /></svg>
                            }
                            else if (module.Equals("Tracking", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A2 2 0 013 15.382V6.618a2 2 0 011.105-1.789L9 2m0 18l6-3m-6 3V2m6 15l5.447-2.724A2 2 0 0021 12.382V3.618a2 2 0 00-1.105-1.789L15 2m0 15V2m0 0L9 5" /></svg>
                            }
                            else if (module.Equals("Freight Costs", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            }
                            else if (module.Equals("Reports", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-cyan-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-6m3 6V7m3 10v-4M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                            }
                            else if (module.Equals("System Settings", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-1.14 1.603-1.14 1.902 0a1 1 0 001.516.59c.996-.63 2.306.68 1.676 1.676a1 1 0 00.59 1.516c1.14.3 1.14 1.603 0 1.902a1 1 0 00-.59 1.516c.63.996-.68 2.306-1.676 1.676a1 1 0 00-1.516.59c-.3 1.14-1.603 1.14-1.902 0a1 1 0 00-1.516-.59c-.996.63-2.306-.68-1.676-1.676a1 1 0 00-.59-1.516c-1.14-.3-1.14-1.603 0-1.902a1 1 0 00.59-1.516c-.63-.996.68-2.306 1.676-1.676a1 1 0 001.516-.59zM12 10a2 2 0 100 4 2 2 0 000-4z" /></svg>
                            }
                            else if (module.Equals("Audit Logs", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg class="w-4 h-4 text-lime-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-6m3 6V7m3 10v-4M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                            }
                            else
                            {
                                <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
                            }
                            <span>@module</span>
                        </a>
                    }
                }
            </nav>

            <div class="mt-10 pt-6 border-t border-slate-700">
                <a href="@Url.Action("Logout", "Account")" class="inline-flex w-full items-center justify-center px-4 py-2 rounded-lg bg-sky-600 text-white font-semibold hover:bg-sky-500 transition">
                    Logout
                </a>
            </div>
        </aside>

        <main class="flex-1 p-6 lg:p-8">
            <div class="mb-8">
                <h2 class="font-display text-4xl font-bold">Client Dashboard</h2>
                <p class="text-slate-600">Track your shipments and access your assigned modules.</p>
            </div>

            <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-4 mb-6">
                <div class="rounded-2xl bg-white border border-slate-200 p-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">Total</p>
                    <p class="text-2xl font-bold mt-1">@Model.TotalMyShipments</p>
                </div>
                <div class="rounded-2xl bg-white border border-slate-200 p-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">Pending</p>
                    <p class="text-2xl font-bold text-amber-600 mt-1">@Model.MyPendingShipments</p>
                </div>
                <div class="rounded-2xl bg-white border border-slate-200 p-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">In Transit</p>
                    <p class="text-2xl font-bold text-cyan-600 mt-1">@Model.MyInTransitShipments</p>
                </div>
                <div class="rounded-2xl bg-white border border-slate-200 p-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">Delivered</p>
                    <p class="text-2xl font-bold text-emerald-600 mt-1">@Model.MyDeliveredShipments</p>
                </div>
                <div class="rounded-2xl bg-white border border-slate-200 p-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">Completed</p>
                    <p class="text-2xl font-bold text-sky-600 mt-1">@Model.MyCompletedShipments</p>
                </div>
                <div class="rounded-2xl bg-white border border-slate-200 p-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wider">Cancelled</p>
                    <p class="text-2xl font-bold text-red-600 mt-1">@Model.MyCancelledShipments</p>
                </div>
            </section>

            <section id="modules" class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
                <div class="lg:col-span-2 rounded-2xl bg-white border border-slate-200">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="font-display text-2xl font-bold">Recent My Shipments</h2>
                    </div>
                    <div class="divide-y divide-slate-100">
                        @if (Model.RecentShipments.Count == 0)
                        {
                            <p class="px-6 py-6 text-slate-500">No shipments yet.</p>
                        }
                        else
                        {
                            @foreach (var shipment in Model.RecentShipments)
                            {
                                <div class="px-6 py-4 flex items-center justify-between gap-4">
                                    <div>
                                        <p class="font-semibold text-slate-900">@shipment.ShipmentCode</p>
                                        <p class="text-sm text-slate-500">@shipment.Origin -> @shipment.Destination</p>
                                        <p class="text-xs text-slate-400 mt-1">
                                            Carrier: @(shipment.Carrier?.Name ?? "Unassigned")
                                            • Scheduled: @shipment.ScheduledDate.ToString("yyyy-MM-dd")
                                        </p>
                                    </div>
                                    <span class="px-2 py-1 rounded-full text-xs bg-slate-100 text-slate-700">@shipment.Status</span>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="rounded-2xl bg-white border border-slate-200 p-6 lg:col-span-1">
                    <h2 class="font-display text-2xl font-bold mb-4">My Shipment Summary</h2>
                    <div class="grid grid-cols-2 gap-3 text-sm mb-5">
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Total: <span class="font-semibold">@Model.TotalMyShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Pending: <span class="font-semibold">@Model.MyPendingShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">In Transit: <span class="font-semibold">@Model.MyInTransitShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Delivered: <span class="font-semibold">@Model.MyDeliveredShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Completed: <span class="font-semibold">@Model.MyCompletedShipments</span></div>
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Cancelled: <span class="font-semibold">@Model.MyCancelledShipments</span></div>
                    </div>
                    <h2 class="font-display text-2xl font-bold mb-4">Quick Actions</h2>
                    <div class="space-y-3">
                        @if (Model.AssignedModules.Any(m => m.Equals("Tracking", StringComparison.OrdinalIgnoreCase)))
                        {
                            <a href="@Url.Action("Index","Tracking")" class="block text-center px-4 py-2.5 rounded-lg bg-sky-600 text-white font-semibold hover:bg-sky-500 transition">Track Shipments</a>
                        }
                        @if (Model.AssignedModules.Any(m => m.Equals("Shipments", StringComparison.OrdinalIgnoreCase)))
                        {
                            <a href="@Url.Action("Index","Shipment")" class="block text-center px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 font-semibold hover:bg-slate-100 transition">View Shipment Module</a>
                        }
                    </div>
                </div>
            </section>

            @if (Model.CanViewAuditLogs)
            {
                <section id="logs" class="rounded-2xl bg-white border border-slate-200">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="font-display text-2xl font-bold">Recent Activity Logs</h2>
                    </div>
                    <div class="divide-y divide-slate-100">
                        @if (Model.RecentActivities.Count == 0)
                        {
                            <p class="px-6 py-6 text-slate-500">No recent activities.</p>
                        }
                        else
                        {
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <div class="px-6 py-4">
                                    <div class="flex items-center justify-between gap-4">
                                        <p class="text-sm text-slate-800">@activity.Action</p>
                                        <span class="text-xs text-slate-400">@activity.Timestamp.ToString("MMM dd, hh:mm tt")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </section>
            }
        </main>
    </div>
</body>
</html>
