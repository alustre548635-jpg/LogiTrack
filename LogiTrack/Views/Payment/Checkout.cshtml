@{
    Layout = null;
    ViewData["Title"] = "Checkout - LogiTrack";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout - LogiTrack</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen">
    <div class="max-w-3xl mx-auto px-6 py-14">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8">
            <h1 class="text-3xl font-bold text-slate-900">Complete Your Subscription</h1>
            <p class="text-slate-600 mt-2">You are subscribing to the <strong>@ViewBag.PlanName</strong> plan.</p>

            @if (TempData["PaymentError"] != null)
            {
                <div class="mt-5 rounded-lg border border-red-200 bg-red-50 text-red-700 px-4 py-3 text-sm">
                    @TempData["PaymentError"]
                </div>
            }

            <div class="mt-8 rounded-xl border border-slate-200 bg-slate-50 p-5">
                <div class="flex items-center justify-between text-slate-700">
                    <span>Plan</span>
                    <span class="font-semibold">@ViewBag.PlanName</span>
                </div>
                <div class="mt-3 flex items-center justify-between text-slate-700">
                    <span>Billing</span>
                    <span class="font-semibold">Monthly</span>
                </div>
                <div class="mt-3 flex items-center justify-between text-slate-900 text-xl font-bold">
                    <span>Total</span>
                    <span>PHP @ViewBag.PlanAmount</span>
                </div>
            </div>

            <form method="post" action="@Url.Action("CreateCheckoutSession", "Payment")" class="mt-8">
                @Html.AntiForgeryToken()
                <input type="hidden" name="plan" value="@ViewBag.Plan" />
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <button type="submit" class="w-full rounded-xl bg-blue-600 text-white py-3.5 font-semibold hover:bg-blue-700 transition">
                    Pay with PayMongo
                </button>
            </form>

            <a href="@(string.IsNullOrWhiteSpace((string?)ViewBag.ReturnUrl) ? Url.Action("Index", "Home") : ViewBag.ReturnUrl)" class="mt-4 inline-block text-sm text-slate-600 hover:text-slate-900">
                Back to plans
            </a>
        </div>
    </div>
</body>
</html>
