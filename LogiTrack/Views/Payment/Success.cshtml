@{
    Layout = null;
    ViewData["Title"] = "Payment Success - LogiTrack";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Success - LogiTrack</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center px-6">
    <div class="max-w-xl w-full bg-white rounded-2xl shadow-xl border border-slate-200 p-8 text-center">
        <div class="text-5xl">✅</div>
        <h1 class="mt-4 text-3xl font-bold text-slate-900">Payment Completed</h1>
        <p class="mt-2 text-slate-600">
            Your <strong>@ViewBag.Plan</strong> subscription checkout was completed successfully.
        </p>
        <a href="@Url.Action("Index", "Client")" class="mt-8 inline-flex px-6 py-3 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
            Go to Dashboard
        </a>
    </div>
</body>
</html>
