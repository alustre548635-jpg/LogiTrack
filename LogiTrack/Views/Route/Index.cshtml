@model LogiTrack.Models.RouteOptimizationViewModel
@{
 ViewData["Title"] = "Route Optimization";
 ViewData["ActiveNav"] = "Route";
 Layout = "~/Views/Shared/_ModuleLayout.cshtml";
}

<link href="https://api.mapbox.com/mapbox-gl-js/v3.0.1/mapbox-gl.css" rel="stylesheet">
<style>
    .mapboxgl-popup-content { border-radius: 12px; padding: 10px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e2e8f0; font-family: 'Inter', sans-serif; }
    .mapboxgl-popup-close-button { outline: none; padding: 4px; }
</style>

<div x-data="{ 
    waypoints: [''],
    selectedShipments: [],
    selectedDriver: '',
    startHub: '',
    endHub: '',
    departureTime: '',
    vehicleType: 'Truck (10T)',
    recommendedVehicle: '',
    loadCapacity: 75,
    shipments: [
        @foreach (var s in Model.AvailableShipments)
        {
            @:{ id: '@s.ShipmentId', code: '@s.ShipmentCode', origin: '@Html.Raw(s.Origin.Replace("'", "\\'"))', dest: '@Html.Raw(s.Destination.Replace("'", "\\'"))', weight: @s.Weight, date: '@s.ScheduledDate.ToString("yyyy-MM-ddTHH:mm")', warehouse: '@Html.Raw(s.WarehouseName.Replace("'", "\\'"))' },
        }
    ],
    drivers: [
        @foreach (var d in Model.AvailableDrivers)
        {
            @:{ id: '@d.DriverId', name: '@Html.Raw(d.FullName.Replace("'", "\\'"))', plate: '@d.VehiclePlate', type: '@d.VehicleType' },
        }
    ],
    hubs: [
        @foreach (var h in Model.HubOptions)
        {
            @:'@Html.Raw(h.Replace("'", "\\'"))',
        }
    ],
    init() {
        this.$watch('startHub', val => { if(window.updateMapMarkers) window.updateMapMarkers(val, this.endHub); });
        this.$watch('endHub', val => { if(window.updateMapMarkers) window.updateMapMarkers(this.startHub, val); });
    },
    toggleShipment(id) {
        if (this.selectedShipments.includes(id)) {
            this.selectedShipments = this.selectedShipments.filter(x => x !== id);
        } else {
            this.selectedShipments.push(id);
            
            // Auto-set hubs based on first selection if not already set
            if (this.selectedShipments.length === 1) {
                const s = this.shipments.find(x => x.id == id);
                if (s) {
                    this.startHub = s.warehouse;
                    const eh = this.hubs.find(h => h.toLowerCase().includes(s.dest.toLowerCase()));
                    if (eh) this.endHub = eh;
                    this.departureTime = s.date;
                }
            }
        }
        this.calculateLoad();
    },
    calculateLoad() {
        let totalWeight = 0;
        this.selectedShipments.forEach(id => {
            const s = this.shipments.find(x => x.id == id);
            if (s) totalWeight += s.weight;
        });

        if (totalWeight <= 100) this.recommendedVehicle = 'Motorcycle';
        else if (totalWeight <= 3000) this.recommendedVehicle = 'Van (3T)';
        else if (totalWeight <= 10000) this.recommendedVehicle = 'Truck (10T)';
        else this.recommendedVehicle = 'Container (30T)';
        
        this.vehicleType = this.recommendedVehicle;
    }
}" class="space-y-5">

 @* PAGE HEADER *@
 <div class="flex items-center justify-between">
 <div>
 <h1 class="font-display text-3xl font-bold text-slate-900 uppercase tracking-wide">Route Optimization</h1>
 <p class="text-sm text-slate-500 mt-0.5">AI-assisted route planning with real-time traffic data</p>
 </div>
 <a href="@Url.Action("Export", "Route")" class="flex items-center gap-2 bg-sky-600 hover:bg-sky-500 text-white font-semibold text-sm px-4 py-2 rounded-xl transition-all hover:shadow-lg hover:shadow-sky-500/20">
 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
 Export Routes
 </a>
 </div>

 <div class="grid grid-cols-5 gap-5">

 @* LEFT: Config Panel (2/5) *@
 <div class="col-span-2 space-y-4">
 <div class="bg-white border border-slate-200 rounded-xl p-5">
 <h2 class="text-sm font-semibold text-slate-800 mb-4 flex items-center gap-2">
 <svg class="w-4 h-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="6" cy="18" r="2" /><circle cx="18" cy="6" r="2" /><path d="M6 16V8a2 2 0 012-2h4M18 8v8a2 2 0 01-2 2h-4" /></svg>
 Route Configuration
 </h2>

 @* AJAX: POST /Route/Optimize on submit *@
 <form id="routeForm" class="space-y-4">
 @Html.AntiForgeryToken()
  <div>
  <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 ">Assign Shipments <span class="text-red-400">*</span></label>
  <div class="border border-slate-200 rounded-xl overflow-hidden max-h-48 overflow-y-auto bg-slate-50">
      <table class="w-full text-xs">
          <thead class="bg-slate-100 text-slate-600 sticky top-0">
              <tr>
                  <th class="p-2 text-left w-8"></th>
                  <th class="p-2 text-left">Code</th>
                  <th class="p-2 text-left">To</th>
                  <th class="p-2 text-right">Wt</th>
              </tr>
          </thead>
          <tbody>
              <template x-for="s in shipments" :key="s.id">
                  <tr class="border-b border-slate-200 hover:bg-sky-50 transition-colors cursor-pointer" @@click="toggleShipment(s.id)">
                      <td class="p-2">
                          <input type="checkbox" :value="s.id" x-model="selectedShipments" class="rounded border-slate-300 text-sky-600 focus:ring-sky-500" @@click.stop>
                      </td>
                      <td class="p-2 font-mono font-bold text-slate-700" x-text="s.code"></td>
                      <td class="p-2 text-slate-600" x-text="s.dest"></td>
                      <td class="p-2 text-right text-slate-500"><span x-text="s.weight"></span>kg</td>
                  </tr>
              </template>
          </tbody>
      </table>
  </div>
  <div class="mt-2 flex items-center justify-between">
      <span class="text-[10px] text-slate-500" x-text="selectedShipments.length + ' shipments selected'"></span>
      <button type="button" @@click="selectedShipments = []" class="text-[10px] text-red-400 hover:text-red-500 font-bold uppercase tracking-wider">Clear</button>
  </div>
  </div>

  <div>
  <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 ">Assign Driver <span class="text-red-400">*</span></label>
  <select name="DriverId" id="DriverId" x-model="selectedDriver" required class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-700 rounded-xl px-3 py-2.5 text-sm outline-none transition-all ">
  <option value="">Select a driver manifest…</option>
  <template x-for="d in drivers" :key="d.id">
      <option :value="d.id" x-text="d.name + ' (' + d.plate + ' – ' + d.type + ')'"></option>
  </template>
  </select>
  <p class="text-[10px] text-slate-400 mt-1" x-show="drivers.length > 0" x-text="drivers.length + ' total active driver(s) available'"></p>
  </div>

 <div>
 <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 ">Start Hub <span class="text-red-400">*</span></label>
 @* AJAX: GET /Hub/List for options *@
 <select name="StartHub" x-model="startHub" required class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-700 rounded-xl px-3 py-2.5 text-sm outline-none transition-all ">
 <option value="">Select origin hub…</option>
 @foreach (var hub in Model.HubOptions)
 {
 <option value="@hub">@hub</option>
 }
 </select>
 </div>

 @* Waypoints *@
 <div>
 <div class="flex items-center justify-between mb-1.5">
 <label class="text-xs uppercase tracking-widest text-slate-500 ">Waypoints</label>
 <button type="button" x-on:click="waypoints.push('')"
 class="text-xs text-cyan-400 hover:text-cyan-300 transition-colors flex items-center gap-1">
 <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" /></svg>
 Add Stop
 </button>
 </div>
 <template x-for="(wp, i) in waypoints" :key="i">
 <div class="flex gap-2 mb-2">
 <input type="text" name="Waypoints" :placeholder="'Stop ' + (i+1) + ' location'"
 x-model="waypoints[i]"
 class="flex-1 bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-800 placeholder:text-slate-600 rounded-xl px-3 py-2 text-sm outline-none transition-all " />
 <button type="button" x-on:click="waypoints.splice(i, 1)" x-show="waypoints.length > 1"
 class="text-slate-600 hover:text-red-400 transition-colors px-2">
 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12" /></svg>
 </button>
 </div>
 </template>
 </div>

 <div>
 <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 ">End Hub <span class="text-red-400">*</span></label>
 <select name="EndHub" x-model="endHub" required class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-700 rounded-xl px-3 py-2.5 text-sm outline-none transition-all ">
 <option value="">Select destination hub…</option>
 @foreach (var hub in Model.HubOptions)
 {
 <option value="@hub">@hub</option>
 }
 </select>
 </div>

 <div class="grid grid-cols-2 gap-3">
 <div>
 <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 ">Vehicle Type</label>
 <select name="VehicleType" x-model="vehicleType" class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-700 rounded-xl px-3 py-2.5 text-sm outline-none ">
 <option value="Truck (10T)">Truck (10T)</option>
 <option value="Van (3T)">Van (3T)</option>
 <option value="Motorcycle">Motorcycle</option>
 <option value="Container (30T)">Container (30T)</option>
 </select>
 </div>
 <div>
 <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 ">Departure</label>
 <input type="datetime-local" name="DepartureTime" x-model="departureTime"
 class="w-full bg-slate-50 border border-slate-300 focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 text-slate-600 rounded-xl px-3 py-2.5 text-sm outline-none " />
 </div>
 </div>

 <div>
  <div class="flex items-center justify-between mb-2">
      <label class="block text-xs uppercase tracking-widest text-slate-500 ">Load Capacity</label>
      <template x-if="selectedShipments.length > 0">
          <span class="text-[10px] bg-sky-100 text-sky-700 px-2 py-0.5 rounded-full font-bold">
              <span x-text="selectedShipments.length"></span> Shipments Loaded
          </span>
      </template>
  </div>
 <input type="range" name="LoadCapacity" min="10" max="100" x-model="loadCapacity" class="w-full accent-sky-500" />
 <div class="flex items-center justify-between mt-1">
 <span class="text-xs text-slate-600 ">10%</span>
 <span class="text-xs text-sky-600 font-bold" x-text="loadCapacity + '%'"></span>
 <span class="text-xs text-slate-600 ">100%</span>
 </div>
 </div>

 <div>
 <label class="block text-xs uppercase tracking-widest text-slate-500 mb-2 ">Optimization Priority</label>
 <div class="grid grid-cols-3 gap-2">
 @foreach (var opt in new[] { ("Fastest", "⚡"), ("Cheapest", "₱"), ("Eco", "🌿") })
 {
 <label class="relative cursor-pointer">
 <input type="radio" name="OptPriority" value="@opt.Item1" class="sr-only peer" @(opt.Item1 == "Fastest" ? "checked" : "") />
 <div class="flex flex-col items-center py-2.5 rounded-xl border border-slate-200 text-xs text-slate-600 peer-checked:border-sky-500 peer-checked:bg-sky-50 peer-checked:text-sky-600 transition-all cursor-pointer">
 <span class="text-base mb-0.5">@opt.Item2</span>
 @opt.Item1
 </div>
 </label>
 }
 </div>
 </div>

 <button type="button" onclick="optimizeRoute()"
 class="w-full bg-sky-600 hover:bg-sky-500 text-white font-semibold py-3 rounded-xl transition-all text-sm hover:shadow-lg hover:shadow-sky-500/20 flex items-center justify-center gap-2">
 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
 Optimize Route
 </button>
 </form>
 </div>
 </div>

 @* RIGHT: Map + Results (3/5) *@
 <div class="col-span-3 space-y-4">

 @* Mapbox Container *@
 <div class="bg-white border border-slate-200 rounded-xl overflow-hidden relative shadow-sm" style="height: 420px;">
     <div id="mapbox-container" class="absolute inset-0 w-full h-full"></div>
     <div id="map-loading" class="absolute inset-0 bg-slate-50/80 flex items-center justify-center z-10 hidden transition-opacity">
         <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-sky-600"></div>
     </div>
 </div>

 @* Summary Stats *@
 <div class="flex items-center gap-6 bg-white border border-slate-200 rounded-xl px-6 py-4 shadow-sm">
 <div class="flex-1 text-center"><p id="summaryDistance" class=" text-lg font-bold text-sky-600">—</p><p class="text-xs uppercase tracking-widest text-slate-500 mt-1">Distance</p></div>
 <div class="w-px h-10 bg-slate-200"></div>
 <div class="flex-1 text-center"><p id="summaryEta" class=" text-lg font-bold text-sky-600">—</p><p class="text-xs uppercase tracking-widest text-slate-500 mt-1">ETA</p></div>
 <div class="w-px h-10 bg-slate-200"></div>
 <div class="flex-1 text-center"><p id="summaryFuel" class=" text-lg font-bold text-sky-600">—</p><p class="text-xs uppercase tracking-widest text-slate-500 mt-1">Fuel Est.</p></div>
 <div class="w-px h-10 bg-slate-200"></div>
 <div class="flex-1 text-center"><p id="summaryToll" class=" text-lg font-bold text-sky-600">—</p><p class="text-xs uppercase tracking-widest text-slate-500 mt-1">Toll Cost</p></div>
 </div>

 @* Route Comparison Cards *@
 <div>
 <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-3">Route Options</h2>
 @* AJAX: GET /Route/Options after optimize *@
 <div id="routeOptions" class="grid grid-cols-3 gap-3">
 <div class="col-span-3 rounded-xl border border-slate-200 bg-slate-50/50 p-4 text-sm text-slate-600 ">
 Click <span class="text-sky-600 font-semibold">Optimize Route</span> to generate route options.
 </div>
 </div>
 </div>

 <div class="bg-white border border-slate-200 rounded-xl p-4">
 <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-3">Recent Saved Routes</h2>
 <div class="overflow-x-auto">
 <table class="w-full text-sm">
 <thead>
 <tr class="text-left text-slate-500 border-b border-slate-200">
 <th class="py-2 pr-3">Route</th>
 <th class="py-2 pr-3">Distance</th>
 <th class="py-2 pr-3">ETA</th>
 <th class="py-2 pr-3">Type</th>
 <th class="py-2 pr-3">Status</th>
 </tr>
 </thead>
 <tbody>
 @if (Model.RecentRoutes.Count == 0)
 {
 <tr><td colspan="5" class="py-3 text-slate-500">No saved routes yet.</td></tr>
 }
 @foreach (var route in Model.RecentRoutes)
 {
 <tr class="border-b border-slate-200">
 <td class="py-2 pr-3 text-slate-700">@route.StartHub → @route.EndHub</td>
 <td class="py-2 pr-3 text-slate-600">@route.DistanceKm.ToString("0.##") km</td>
 <td class="py-2 pr-3 text-slate-600">@(route.EstimatedMinutes / 60)h @(route.EstimatedMinutes % 60)m</td>
 <td class="py-2 pr-3 text-slate-600">@route.OptimizationType</td>
 <td class="py-2 pr-3 text-slate-700">@route.Status</td>
 </tr>
 }
 </tbody>
 </table>
 </div>
 </div>
 </div>
 </div>
</div>

@section Scripts {
 <script src="https://api.mapbox.com/mapbox-gl-js/v3.0.1/mapbox-gl.js"></script>
 <script>
 window.currentRoutes = [];

 // Mapbox Integration
 mapboxgl.accessToken = 'YOUR_MAPBOX_ACCESS_TOKEN_HERE';
 
 const hubCoords = {
     'Manila Central Hub': [120.9842, 14.5995],
     'QC Distribution Center': [121.0437, 14.6760],
     'Cebu City Hub': [123.8854, 10.3157],
     'Davao Distribution': [125.6001, 7.1907],
     'default': [121.0000, 14.6000]
 };
 
 let map;
 let markers = [];
 let routeLayerId = 'route-layer';

 document.addEventListener('DOMContentLoaded', () => {
     map = new mapboxgl.Map({
         container: 'mapbox-container',
         style: 'mapbox://styles/mapbox/navigation-day-v1',
         center: hubCoords['Manila Central Hub'],
         zoom: 5,
         attributionControl: false
     });
     map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'top-right');
 });

 window.updateMapMarkers = function(start, end) {
     if(!map) return;
     
     // clear existing
     markers.forEach(m => m.remove());
     markers = [];
     if(map.getSource('route')) {
         map.removeLayer(routeLayerId);
         map.removeSource('route');
     }

     const bounds = new mapboxgl.LngLatBounds();
     let hasValidCoords = false;

     if (start && hubCoords[start]) {
         const el = document.createElement('div');
         el.innerHTML = `<div class="w-4 h-4 bg-sky-500 rounded-full border-2 border-white shadow-lg"></div>`;
         const m1 = new mapboxgl.Marker(el).setLngLat(hubCoords[start]).setPopup(new mapboxgl.Popup({offset: 15}).setHTML(`<p class="font-bold text-slate-800 text-[11px] uppercase tracking-wider">Start</p><p class="text-sm">${start}</p>`)).addTo(map);
         markers.push(m1);
         bounds.extend(hubCoords[start]);
         hasValidCoords = true;
     }

     if (end && hubCoords[end]) {
         const el = document.createElement('div');
         el.innerHTML = `<div class="w-4 h-4 bg-red-500 rounded-full border-2 border-white shadow-lg"></div>`;
         const m2 = new mapboxgl.Marker(el).setLngLat(hubCoords[end]).setPopup(new mapboxgl.Popup({offset: 15}).setHTML(`<p class="font-bold text-slate-800 text-[11px] uppercase tracking-wider">Destination</p><p class="text-sm">${end}</p>`)).addTo(map);
         markers.push(m2);
         bounds.extend(hubCoords[end]);
         hasValidCoords = true;
     }

     if (hasValidCoords) {
         map.fitBounds(bounds, { padding: 60, maxZoom: 12, duration: 1000 });
     }
 };

 async function fetchMapboxDirections(startCoords, endCoords) {
     const url = `https://api.mapbox.com/directions/v5/mapbox/driving/${startCoords[0]},${startCoords[1]};${endCoords[0]},${endCoords[1]}?geometries=geojson&access_token=${mapboxgl.accessToken}`;
     try {
         const res = await fetch(url);
         const json = await res.json();
         if(json.routes && json.routes.length > 0) {
             const route = json.routes[0].geometry;
             
             if(map.getSource('route')) {
                 map.getSource('route').setData(route);
             } else {
                 map.addSource('route', { type: 'geojson', data: route });
                 map.addLayer({
                     id: routeLayerId,
                     type: 'line',
                     source: 'route',
                     layout: { 'line-join': 'round', 'line-cap': 'round' },
                     paint: { 'line-color': '#0ea5e9', 'line-width': 5, 'line-opacity': 0.8 }
                 }); 
             }
         }
     } catch (e) {
         console.error('Directions error:', e);
     }
 }

 function optimizeRoute() {
 const form = document.getElementById('routeForm');
 if(!form.reportValidity()) return;

 const data = new FormData(form);
 fetch('/Route/Optimize', { method: 'POST', body: data })
 .then(r => r.json())
 .then(result => {
 if (!result.success) {
 window.showToast(result.message || 'Failed to optimize route.', 'error');
 return;
 }

 window.currentRoutes = result.routes;

 document.getElementById('summaryDistance').textContent = result.summary.distance;
 document.getElementById('summaryEta').textContent = result.summary.eta;
 document.getElementById('summaryFuel').textContent = result.summary.fuel;
 document.getElementById('summaryToll').textContent = result.summary.toll;

 const container = document.getElementById('routeOptions');
 const cards = result.routes.map((r) => {
 const carbonColor = r.carbon === 'Low' ? 'text-emerald-400' : (r.carbon === 'Medium' ? 'text-sky-600' : 'text-red-400');
 const tagClass = r.highlighted ? 'bg-sky-100 text-sky-600' : 'bg-slate-100 text-slate-500';
 const buttonClass = r.highlighted
 ? 'bg-sky-600 hover:bg-sky-500 text-white'
 : 'bg-slate-100 hover:bg-slate-200 text-slate-700';
 return `
 <div class="bg-white border ${r.highlighted ? 'border-sky-500/50' : 'border-slate-200'} rounded-xl p-4 hover:border-slate-300 transition-all">
 <div class="text-xs ${tagClass} rounded-full px-2.5 py-0.5 inline-block mb-3">${r.label}</div>
 <div class="space-y-1.5 mb-4">
 <div class="flex justify-between"><span class="text-xs text-slate-500 ">Distance</span><span class="text-xs text-slate-700 font-semibold">${r.dist}</span></div>
 <div class="flex justify-between"><span class="text-xs text-slate-500 ">ETA</span><span class="text-xs text-slate-700 font-semibold">${r.eta}</span></div>
 <div class="flex justify-between"><span class="text-xs text-slate-500 ">Fuel</span><span class="text-xs text-slate-700 font-semibold">${r.fuel}</span></div>
 <div class="flex justify-between"><span class="text-xs text-slate-500 ">Toll</span><span class="text-xs text-slate-700 font-semibold">${r.toll}</span></div>
 <div class="flex justify-between"><span class="text-xs text-slate-500 ">Carbon</span><span class="text-xs ${carbonColor} ">${r.carbon}</span></div>
 </div>
 <button onclick="selectRoute('${r.id}')" class="w-full py-2 rounded-lg text-xs font-semibold transition-colors ${buttonClass}">
 Select This Route
 </button>
 </div>
 `;
 }).join('');
 container.innerHTML = cards;

 // Draw the real route on the map
 const start = form.StartHub.value;
 const end = form.EndHub.value;
 if (start && end && hubCoords[start] && hubCoords[end]) {
     document.getElementById('map-loading').classList.remove('hidden');
     fetchMapboxDirections(hubCoords[start], hubCoords[end]).finally(() => {
         document.getElementById('map-loading').classList.add('hidden');
     });
 }
 });
 }
  async function selectRoute(routeId) {
      const selected = window.currentRoutes.find(r => r.id === routeId);
      if (!selected) return;

      const confirmed = await window.showConfirm(
          'Confirm Route Selection',
          `Select the ${selected.label} route?\n\nDistance: ${selected.dist}\nETA: ${selected.eta}\nFuel: ${selected.fuel}`
      );
      if (!confirmed) return;

      const form = document.getElementById('routeForm');
      const data = new FormData();

      // Anti-forgery token
      const tokenEl = form.querySelector('input[name="__RequestVerificationToken"]');
      if (tokenEl) data.append('__RequestVerificationToken', tokenEl.value);

      // Multi-shipment support (DOM-based)
      const checkboxes = form.querySelectorAll('input[type="checkbox"]:checked');
      checkboxes.forEach(cb => {
          data.append('ShipmentIds', cb.value);
      });
      
      data.append('DriverId', form.DriverId.value);
      data.append('StartHub', form.StartHub.value);
      data.append('EndHub', form.EndHub.value);
      data.append('VehicleType', form.VehicleType.value);
      data.append('LoadCapacity', form.LoadCapacity.value);
      data.append('DistanceKm', selected.rawDistance);
      data.append('EstimatedMinutes', selected.rawMinutes);
      data.append('FuelCostEstimate', selected.rawFuel);
      data.append('TollCost', selected.rawToll);
      data.append('OptimizationType', selected.label);

      fetch('/Route/Select', { method: 'POST', body: data })
      .then(r => r.json())
      .then(result => {
          if (!result.success) {
              window.showToast(result.message || 'Unable to select route.', 'error');
              return;
          }
          window.showToast(result.message || 'Route selected successfully.');
          setTimeout(() => { window.location.href = window.location.pathname + '?t=' + Date.now(); }, 1800);
      })
      .catch(err => {
          window.showToast('Network error while selecting route.', 'error');
      });
  }
 </script>
}
