@model LogiTrack.Models.RouteOptimizationViewModel
@{
    ViewData["Title"] = "Route Optimization";
    ViewData["ActiveNav"] = "Route";
}

<div x-data="{ selectedRoute: null, waypoints: [''] }" class="space-y-5">

    @* PAGE HEADER *@
    <div class="flex items-center justify-between">
        <div>
            <h1 class="font-display text-3xl font-bold text-slate-100 uppercase tracking-wide">Route Optimization</h1>
            <p class="text-sm text-slate-500 font-mono mt-0.5">AI-assisted route planning with real-time traffic data</p>
        </div>
        <button class="flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold text-sm px-4 py-2 rounded-xl transition-all hover:shadow-lg hover:shadow-amber-500/20">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Export Routes
        </button>
    </div>

    <div class="grid grid-cols-5 gap-5">

        @* LEFT: Config Panel (2/5) *@
        <div class="col-span-2 space-y-4">
            <div class="bg-slate-800/60 border border-slate-700/50 rounded-xl p-5">
                <h2 class="text-sm font-semibold text-slate-200 mb-4 flex items-center gap-2">
                    <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="6" cy="18" r="2" /><circle cx="18" cy="6" r="2" /><path d="M6 16V8a2 2 0 012-2h4M18 8v8a2 2 0 01-2 2h-4" /></svg>
                    Route Configuration
                </h2>

                @* AJAX: POST /Route/Optimize on submit *@
                <form id="routeForm" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 font-mono">Start Hub <span class="text-red-400">*</span></label>
                        @* AJAX: GET /Hub/List for options *@
                        <select name="StartHub" required class="w-full bg-slate-800 border border-slate-600 focus:border-amber-500 text-slate-300 rounded-xl px-3 py-2.5 text-sm outline-none transition-all font-mono">
                            <option value="">Select origin hub…</option>
                            @foreach (var hub in Model.HubOptions)
                            {
                                <option value="@hub">@hub</option>
                            }
                        </select>
                    </div>

                    @* Waypoints *@
                    <div>
                        <div class="flex items-center justify-between mb-1.5">
                            <label class="text-xs uppercase tracking-widest text-slate-500 font-mono">Waypoints</label>
                            <button type="button" @@click="waypoints.push('')"
                                    class="text-xs text-cyan-400 hover:text-cyan-300 font-mono transition-colors flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" /></svg>
                                Add Stop
                            </button>
                        </div>
                        <template x-for="(wp, i) in waypoints" :key="i">
                            <div class="flex gap-2 mb-2">
                                <input type="text" name="Waypoints" :placeholder="'Stop ' + (i+1) + ' location'"
                                       x-model="waypoints[i]"
                                       class="flex-1 bg-slate-800 border border-slate-600 focus:border-amber-500 text-slate-200 placeholder:text-slate-600 rounded-xl px-3 py-2 text-sm outline-none transition-all font-mono" />
                                <button type="button" @@click="waypoints.splice(i, 1)" x-show="waypoints.length > 1"
                                        class="text-slate-600 hover:text-red-400 transition-colors px-2">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12" /></svg>
                                </button>
                            </div>
                        </template>
                    </div>

                    <div>
                        <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 font-mono">End Hub <span class="text-red-400">*</span></label>
                        <select name="EndHub" required class="w-full bg-slate-800 border border-slate-600 focus:border-amber-500 text-slate-300 rounded-xl px-3 py-2.5 text-sm outline-none transition-all font-mono">
                            <option value="">Select destination hub…</option>
                            @foreach (var hub in Model.HubOptions)
                            {
                                <option value="@hub">@hub</option>
                            }
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 font-mono">Vehicle Type</label>
                            <select name="VehicleType" class="w-full bg-slate-800 border border-slate-600 focus:border-amber-500 text-slate-300 rounded-xl px-3 py-2.5 text-sm outline-none font-mono">
                                <option>Truck (10T)</option>
                                <option>Van (3T)</option>
                                <option>Motorcycle</option>
                                <option>Container (30T)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs uppercase tracking-widest text-slate-500 mb-1.5 font-mono">Departure</label>
                            <input type="datetime-local" name="DepartureTime"
                                   class="w-full bg-slate-800 border border-slate-600 focus:border-amber-500 text-slate-400 rounded-xl px-3 py-2.5 text-sm outline-none font-mono" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs uppercase tracking-widest text-slate-500 mb-2 font-mono">Load Capacity</label>
                        <input type="range" name="LoadCapacity" min="10" max="100" value="75" class="w-full accent-amber-500" oninput="document.getElementById('loadVal').textContent=this.value+'%'" />
                        <div class="flex items-center justify-between mt-1">
                            <span class="text-xs text-slate-600 font-mono">10%</span>
                            <span class="text-xs text-amber-400 font-mono font-bold" id="loadVal">75%</span>
                            <span class="text-xs text-slate-600 font-mono">100%</span>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs uppercase tracking-widest text-slate-500 mb-2 font-mono">Optimization Priority</label>
                        <div class="grid grid-cols-3 gap-2">
                            @foreach (var opt in new[] { ("Fastest", "⚡"), ("Cheapest", "₱"), ("Eco", "🌿") })
                            {
                                <label class="relative cursor-pointer">
                                    <input type="radio" name="OptPriority" value="@opt.Item1" class="sr-only peer" @(opt.Item1 == "Fastest" ? "checked" : "") />
                                    <div class="flex flex-col items-center py-2.5 rounded-xl border border-slate-700 text-xs font-mono text-slate-400 peer-checked:border-amber-500 peer-checked:bg-amber-500/10 peer-checked:text-amber-400 transition-all cursor-pointer">
                                        <span class="text-base mb-0.5">@opt.Item2</span>
                                        @opt.Item1
                                    </div>
                                </label>
                            }
                        </div>
                    </div>

                    <button type="button" onclick="optimizeRoute()"
                            class="w-full bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold py-3 rounded-xl transition-all text-sm hover:shadow-lg hover:shadow-amber-500/20 flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        Optimize Route
                    </button>
                </form>
            </div>
        </div>

        @* RIGHT: Map + Results (3/5) *@
        <div class="col-span-3 space-y-4">

            @* Map *@
            <div class="bg-slate-800/60 border border-slate-700/50 rounded-xl overflow-hidden relative">
                @* Google Maps API: initRouteMap() — Directions API for route drawing *@
                @* AJAX: POST /Route/Optimize → draw polyline on map *@
                <div id="routeMap" class="w-full h-72 bg-slate-900 flex items-center justify-center">
                    <div class="text-center">
                        <svg class="w-12 h-12 text-slate-700 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                            <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                        </svg>
                        <p class="text-slate-600 text-sm font-mono">Configure route and click Optimize</p>
                        <p class="text-slate-700 text-xs font-mono mt-1">Google Maps Directions API</p>
                    </div>
                </div>
                @* Route stats chip *@
                <div class="absolute bottom-3 left-3 flex items-center gap-3 bg-slate-900/95 border border-slate-700 rounded-xl px-4 py-2.5 z-10">
                    <div class="text-center"><p id="summaryDistance" class="font-mono text-sm font-bold text-slate-200">—</p><p class="text-xs text-slate-500 font-mono">Distance</p></div>
                    <div class="w-px h-8 bg-slate-700"></div>
                    <div class="text-center"><p id="summaryEta" class="font-mono text-sm font-bold text-slate-200">—</p><p class="text-xs text-slate-500 font-mono">ETA</p></div>
                    <div class="w-px h-8 bg-slate-700"></div>
                    <div class="text-center"><p id="summaryFuel" class="font-mono text-sm font-bold text-slate-200">—</p><p class="text-xs text-slate-500 font-mono">Fuel Est.</p></div>
                    <div class="w-px h-8 bg-slate-700"></div>
                    <div class="text-center"><p id="summaryToll" class="font-mono text-sm font-bold text-slate-200">—</p><p class="text-xs text-slate-500 font-mono">Toll Cost</p></div>
                </div>
            </div>

            @* Route Comparison Cards *@
            <div>
                <h2 class="text-xs uppercase tracking-widest text-slate-500 font-mono mb-3">Route Options</h2>
                @* AJAX: GET /Route/Options after optimize *@
                <div id="routeOptions" class="grid grid-cols-3 gap-3">
                    <div class="col-span-3 rounded-xl border border-slate-700 bg-slate-800/50 p-4 text-sm text-slate-400 font-mono">
                        Click <span class="text-amber-400 font-semibold">Optimize Route</span> to generate route options.
                    </div>
                </div>
            </div>

            <div class="bg-slate-800/60 border border-slate-700/50 rounded-xl p-4">
                <h2 class="text-xs uppercase tracking-widest text-slate-500 font-mono mb-3">Recent Saved Routes</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-slate-500 border-b border-slate-700">
                                <th class="py-2 pr-3">Route</th>
                                <th class="py-2 pr-3">Distance</th>
                                <th class="py-2 pr-3">ETA</th>
                                <th class="py-2 pr-3">Type</th>
                                <th class="py-2 pr-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentRoutes.Count == 0)
                            {
                                <tr><td colspan="5" class="py-3 text-slate-500">No saved routes yet.</td></tr>
                            }
                            @foreach (var route in Model.RecentRoutes)
                            {
                                <tr class="border-b border-slate-800">
                                    <td class="py-2 pr-3 text-slate-300">@route.StartHub → @route.EndHub</td>
                                    <td class="py-2 pr-3 text-slate-400">@route.DistanceKm.ToString("0.##") km</td>
                                    <td class="py-2 pr-3 text-slate-400">@(route.EstimatedMinutes / 60)h @(route.EstimatedMinutes % 60)m</td>
                                    <td class="py-2 pr-3 text-slate-400">@route.OptimizationType</td>
                                    <td class="py-2 pr-3 text-slate-300">@route.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function optimizeRoute() {
            const form = document.getElementById('routeForm');
            const data = new FormData(form);
            fetch('/Route/Optimize', { method: 'POST', body: data })
                .then(r => r.json())
                .then(result => {
                    if (!result.success) {
                        alert(result.message || 'Failed to optimize route.');
                        return;
                    }

                    document.getElementById('summaryDistance').textContent = result.summary.distance;
                    document.getElementById('summaryEta').textContent = result.summary.eta;
                    document.getElementById('summaryFuel').textContent = result.summary.fuel;
                    document.getElementById('summaryToll').textContent = result.summary.toll;

                    const container = document.getElementById('routeOptions');
                    const cards = result.routes.map((r) => {
                        const carbonColor = r.carbon === 'Low' ? 'text-emerald-400' : (r.carbon === 'Medium' ? 'text-amber-400' : 'text-red-400');
                        const tagClass = r.highlighted ? 'bg-amber-500/20 text-amber-400' : 'bg-slate-700/60 text-slate-500';
                        const buttonClass = r.highlighted
                            ? 'bg-amber-500 hover:bg-amber-400 text-slate-900'
                            : 'bg-slate-700 hover:bg-slate-600 text-slate-300';
                        return `
                            <div class="bg-slate-800/60 border ${r.highlighted ? 'border-amber-500/50' : 'border-slate-700/50'} rounded-xl p-4 hover:border-slate-600 transition-all">
                                <div class="text-xs ${tagClass} font-mono rounded-full px-2.5 py-0.5 inline-block mb-3">${r.label}</div>
                                <div class="space-y-1.5 mb-4">
                                    <div class="flex justify-between"><span class="text-xs text-slate-500 font-mono">Distance</span><span class="text-xs text-slate-300 font-mono font-semibold">${r.dist}</span></div>
                                    <div class="flex justify-between"><span class="text-xs text-slate-500 font-mono">ETA</span><span class="text-xs text-slate-300 font-mono font-semibold">${r.eta}</span></div>
                                    <div class="flex justify-between"><span class="text-xs text-slate-500 font-mono">Fuel</span><span class="text-xs text-slate-300 font-mono font-semibold">${r.fuel}</span></div>
                                    <div class="flex justify-between"><span class="text-xs text-slate-500 font-mono">Toll</span><span class="text-xs text-slate-300 font-mono font-semibold">${r.toll}</span></div>
                                    <div class="flex justify-between"><span class="text-xs text-slate-500 font-mono">Carbon</span><span class="text-xs ${carbonColor} font-mono">${r.carbon}</span></div>
                                </div>
                                <button onclick="selectRoute('${r.id}')" class="w-full py-2 rounded-lg text-xs font-semibold font-mono transition-colors ${buttonClass}">
                                    Select This Route
                                </button>
                            </div>
                        `;
                    }).join('');
                    container.innerHTML = cards;
                });
        }
        function selectRoute(id) {
            const data = new FormData();
            data.append('id', id);
            fetch('/Route/Select', { method: 'POST', body: data })
                .then(r => r.json())
                .then(result => {
                    if (!result.success) {
                        alert(result.message || 'Unable to select route.');
                        return;
                    }
                    alert(result.message || 'Route selected.');
                });
        }
    </script>
}
