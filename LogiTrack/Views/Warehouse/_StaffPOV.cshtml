@model LogiTrack.Models.WarehouseDashboardViewModel

<div class="space-y-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
            <h1 class="font-display text-4xl font-bold text-slate-900 uppercase tracking-wide">Warehouse Operations</h1>
            <p class="text-slate-600">Daily tasks, inbound receiving, and outbound dispatching.</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="px-3 py-2 rounded-xl text-sm border border-slate-200 bg-white text-slate-700 font-semibold shadow-sm">
                <svg class="w-4 h-4 inline-block mr-1 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                @Model.SelectedWarehouse?.Name
            </span>
        </div>
    </div>

    <!-- Action Metric Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-2xl bg-amber-50 border border-amber-100 p-5 shadow-sm">
            <p class="text-xs text-amber-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg> Arriving Today</p>
            <p class="text-3xl font-bold text-amber-600 mt-2">@Model.InboundPending</p>
            <p class="text-xs text-amber-600/80 mt-1">Shipments pending arrival</p>
        </div>
        <div class="rounded-2xl bg-sky-50 border border-sky-100 p-5 shadow-sm">
            <p class="text-xs text-sky-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg> To Be Packed</p>
            <p class="text-3xl font-bold text-sky-600 mt-2">@Model.OutboundInTransit</p>
            <p class="text-xs text-sky-600/80 mt-1">Shipments awaiting dispatch</p>
        </div>
        <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-5 shadow-sm">
            <p class="text-xs text-emerald-600 uppercase tracking-wider font-semibold flex items-center gap-1"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> Dispatched Today</p>
            <p class="text-3xl font-bold text-emerald-600 mt-2">@Model.DeliveredToday</p>
            <p class="text-xs text-emerald-600/80 mt-1">Successfully left the warehouse</p>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <!-- Inbound Tasks -->
        <div class="rounded-2xl bg-white border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                <h2 class="font-display text-2xl font-bold text-slate-900">Inbound (Receiving)</h2>
                <p class="text-xs text-slate-500">Scan or mark shipments as they arrive.</p>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.InboundShipments.Count == 0)
                {
                    <p class="p-6 text-slate-500 text-sm">No incoming shipments.</p>
                }
                else
                {
                    @foreach (var s in Model.InboundShipments)
                    {
                        <div class="p-6 hover:bg-slate-50 transition">
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                <div>
                                    <p class="font-mono font-bold text-slate-900 text-lg">@s.ShipmentCode</p>
                                    <p class="text-sm text-slate-600">From: @s.Origin</p>
                                    <div class="mt-2 flex gap-2">
                                        <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded-md font-semibold">@s.CargoType</span>
                                        <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded-md font-semibold">@s.Weight kg</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(s.SpecialHandling))
                                    {
                                        <p class="text-xs text-red-600 font-semibold mt-2">? @s.SpecialHandling</p>
                                    }
                                </div>
                                <button type="button" onclick="updateStatus(@s.ShipmentId, 'Received at Warehouse')" class="w-full sm:w-auto px-6 py-3 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-xl shadow-sm transition">
                                    Mark as Received
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Outbound Tasks -->
        <div class="rounded-2xl bg-white border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                <h2 class="font-display text-2xl font-bold text-slate-900">Outbound (Dispatching)</h2>
                <p class="text-xs text-slate-500">Load shipments onto outbound trucks.</p>
            </div>
            <div class="divide-y divide-slate-100">
                @if (Model.OutboundShipments.Count == 0)
                {
                    <p class="p-6 text-slate-500 text-sm">No shipments ready for dispatch.</p>
                }
                else
                {
                    @foreach (var s in Model.OutboundShipments)
                    {
                        <div class="p-6 hover:bg-slate-50 transition">
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                <div>
                                    <p class="font-mono font-bold text-slate-900 text-lg">@s.ShipmentCode</p>
                                    <p class="text-sm text-slate-600">To: @s.Destination</p>
                                    <div class="mt-2 flex gap-2">
                                        <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded-md font-semibold">@s.CargoType</span>
                                        <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded-md font-semibold">@s.Weight kg</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(s.SpecialHandling))
                                    {
                                        <p class="text-xs text-red-600 font-semibold mt-2">? @s.SpecialHandling</p>
                                    }
                                </div>
                                <button type="button" onclick="updateStatus(@s.ShipmentId, 'In Transit')" class="w-full sm:w-auto px-6 py-3 bg-sky-600 hover:bg-sky-700 text-white font-bold rounded-xl shadow-sm transition">
                                    Load on Truck
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div id="wh-confirm-overlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4" style="display:none;">
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl animate-[fadeScaleIn_0.2s_ease-out]">
        <div class="flex items-start gap-3">
            <div class="mt-0.5 rounded-full bg-amber-100 p-2.5 text-amber-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div class="flex-1">
                <h3 class="text-base font-semibold text-slate-900">Confirm Status Update</h3>
                <p id="wh-confirm-msg" class="mt-1 text-sm text-slate-600"></p>
            </div>
        </div>
        <div class="mt-6 flex justify-end gap-2">
            <button type="button" id="wh-confirm-cancel"
                    class="rounded-lg bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-200 transition-colors">
                Cancel
            </button>
            <button type="button" id="wh-confirm-ok"
                    class="rounded-lg bg-amber-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-amber-600 transition-colors shadow-sm">
                Confirm
            </button>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="wh-toast" class="fixed top-5 right-5 z-50 max-w-sm rounded-xl p-4 text-sm font-medium shadow-lg transition-all duration-300 translate-x-[120%] opacity-0 pointer-events-none"
     style="transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease;">
    <div class="flex items-start gap-3">
        <svg id="wh-toast-icon" class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"></svg>
        <span id="wh-toast-msg" class="flex-1"></span>
        <button type="button" onclick="hideWhToast()" class="hover:opacity-80 text-lg leading-none">&times;</button>
    </div>
</div>

<script>
// ── Custom Confirm Modal ──
let _whConfirmResolve = null;

function showWhConfirm(message) {
    return new Promise((resolve) => {
        _whConfirmResolve = resolve;
        document.getElementById('wh-confirm-msg').textContent = message;
        const overlay = document.getElementById('wh-confirm-overlay');
        overlay.style.display = 'flex';
        // Focus the confirm button for accessibility
        setTimeout(() => document.getElementById('wh-confirm-ok').focus(), 50);
    });
}

document.getElementById('wh-confirm-cancel').addEventListener('click', () => {
    document.getElementById('wh-confirm-overlay').style.display = 'none';
    if (_whConfirmResolve) { _whConfirmResolve(false); _whConfirmResolve = null; }
});
document.getElementById('wh-confirm-ok').addEventListener('click', () => {
    document.getElementById('wh-confirm-overlay').style.display = 'none';
    if (_whConfirmResolve) { _whConfirmResolve(true); _whConfirmResolve = null; }
});
document.getElementById('wh-confirm-overlay').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
        e.currentTarget.style.display = 'none';
        if (_whConfirmResolve) { _whConfirmResolve(false); _whConfirmResolve = null; }
    }
});

// ── Custom Toast ──
let _whToastTimer = null;

function showWhToast(message, type) {
    const toast = document.getElementById('wh-toast');
    const icon  = document.getElementById('wh-toast-icon');
    const msg   = document.getElementById('wh-toast-msg');

    // Clear any pending hide
    if (_whToastTimer) { clearTimeout(_whToastTimer); _whToastTimer = null; }

    msg.textContent = message;

    if (type === 'success') {
        toast.className = 'fixed top-5 right-5 z-50 max-w-sm rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-medium text-emerald-700 shadow-lg pointer-events-auto';
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />';
    } else {
        toast.className = 'fixed top-5 right-5 z-50 max-w-sm rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-medium text-red-700 shadow-lg pointer-events-auto';
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />';
    }

    // Slide in
    toast.style.transition = 'transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease';
    toast.style.transform  = 'translateX(0)';
    toast.style.opacity    = '1';

    _whToastTimer = setTimeout(hideWhToast, 3500);
}

function hideWhToast() {
    const toast = document.getElementById('wh-toast');
    toast.style.transform = 'translateX(120%)';
    toast.style.opacity   = '0';
    if (_whToastTimer) { clearTimeout(_whToastTimer); _whToastTimer = null; }
}

// ── Update Status (uses custom confirm + toast) ──
async function updateStatus(shipmentId, status) {
    const confirmed = await showWhConfirm('Change shipment status to: "' + status + '"?');
    if (!confirmed) return;

    const payload = new FormData();
    payload.append('shipmentId', shipmentId);
    payload.append('newStatus', status);

    try {
        const res = await fetch('/Warehouse/UpdateShipmentStatus', {
            method: 'POST',
            body: payload
        });

        if (!res.ok) {
            showWhToast('Server error (' + res.status + '). Please try again.', 'error');
            return;
        }

        const d = await res.json();

        if (d.success) {
            showWhToast(d.message, 'success');
            setTimeout(function() { location.reload(); }, 1200);
        } else {
            showWhToast(d.message || 'Unable to update status.', 'error');
        }
    } catch (err) {
        console.error('UpdateStatus error:', err);
        showWhToast('Network error. Please try again.', 'error');
    }
}
</script>
