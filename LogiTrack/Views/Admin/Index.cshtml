@model LogiTrack.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Super Admin Dashboard";
    ViewData["ActiveNav"] = "admin-overview";
    Layout = "_ModuleLayout";
}

<!-- Alpine state wrapper -->
<div class="flex-1" x-init="activeModule = window.location.hash ? window.location.hash.substring(1) : '@(TempData["ActiveModule"] ?? "overview")'">
    <main class="p-6 lg:p-8">
            <div class="mb-8" x-show="activeModule === 'overview'">
                <h2 class="font-display text-4xl font-bold uppercase tracking-wide">Dashboard</h2>
                <p class="text-slate-600">Manage users and roles, configure system settings, access all modules, and monitor reports/logs.</p>
            </div>
            @if (TempData["AdminSuccess"] != null)
            {
                <div x-data="{ open: true }" x-show="open" class="fixed top-5 right-5 z-50 max-w-sm rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-700 text-sm font-medium shadow-lg">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="flex-1">@TempData["AdminSuccess"]</span>
                        <button type="button" @@click="open = false" class="text-emerald-700 hover:text-emerald-900">Ã—</button>
                    </div>
                </div>
            }
            @if (TempData["AdminError"] != null)
            {
                <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4 text-red-700 text-sm font-medium">
                    @TempData["AdminError"]
                </div>
            }

            <section id="overview" x-show="activeModule === 'overview'" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
                    <div class="rounded-2xl bg-white border border-slate-200 p-5">
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Total Users</p>
                        <p class="text-3xl font-bold mt-2">@Model.TotalUsers</p>
                    </div>
                    <div class="rounded-2xl bg-white border border-slate-200 p-5">
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Active Users</p>
                        <p class="text-3xl font-bold mt-2">@Model.ActiveUsers</p>
                    </div>
                    <div class="rounded-2xl bg-white border border-slate-200 p-5">
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Total Shipments</p>
                        <p class="text-3xl font-bold mt-2">@Model.TotalShipments</p>
                    </div>
                    <div class="rounded-2xl gradient-accent text-white p-5">
                        <p class="text-xs uppercase tracking-wider text-white/80">In Transit</p>
                        <p class="text-3xl font-bold mt-2">@Model.InTransitShipments</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                    <div class="rounded-2xl bg-white border border-slate-200 p-6">
                        <h3 class="font-display text-2xl font-bold mb-4">Users by Role</h3>
                        <div class="mx-auto" style="max-width: 280px; max-height: 280px;">
                            <canvas id="usersByRoleChart"></canvas>
                        </div>
                    </div>
                    <div class="rounded-2xl bg-white border border-slate-200 p-6">
                        <h3 class="font-display text-2xl font-bold mb-4">Operational Status</h3>
                        <canvas id="opsStatusChart" height="70"></canvas>
                    </div>
                </div>
            </section>

            <section id="manage-users"
                     x-show="activeModule === 'manage-users'"
                     x-data="{
                        userSearch: '',
                        roleFilter: 'all',
                        statusFilter: 'all',
                        matchesRow(row) {
                            const name = (row.dataset.name || '').toLowerCase();
                            const role = (row.dataset.role || '').toLowerCase();
                            const status = (row.dataset.status || '').toLowerCase();
                            const search = this.userSearch.toLowerCase();
                            const roleOk = this.roleFilter === 'all' || role === this.roleFilter;
                            const statusOk = this.statusFilter === 'all' || status === this.statusFilter;
                            const searchOk = search === '' || name.includes(search);
                            return roleOk && statusOk && searchOk;
                        }
                     }"
                     class="rounded-2xl bg-white border border-slate-200 p-6 mb-6">
                <h3 class="font-display text-3xl font-bold mb-3">Manage Users and Roles</h3>
                <div class="grid grid-cols-2 md:grid-cols-5 gap-3 text-sm mb-6">
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Admins: <span class="font-semibold">@Model.AdminUsers</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Managers: <span class="font-semibold">@Model.ManagerUsers</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Staff: <span class="font-semibold">@Model.StaffUsers</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Drivers: <span class="font-semibold">@Model.DriverUsers</span></div>
                </div>

                <div class="rounded-xl border border-slate-200 p-4 mb-6" x-data="{ createRole: '' }">
                    <h4 class="font-semibold text-slate-900 mb-3">Add User</h4>
                    <form method="post" action="@Url.Action("CreateUser","Admin")" class="grid grid-cols-1 md:grid-cols-5 gap-3">
                        @Html.AntiForgeryToken()
                        <input type="text" name="FullName" required placeholder="Full name" class="md:col-span-1 bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500" />
                        <input type="email" name="Email" required placeholder="Email" class="md:col-span-1 bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500" />
                        <select name="Role" required x-model="createRole" class="md:col-span-1 bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                            <option value="">Role</option>
                            <option>Manager</option>
                            <option>Staff</option>
                            <option>Driver</option>
                        </select>
                        <select name="WarehouseId" x-show="createRole === 'Staff'" x-bind:required="createRole === 'Staff'" class="md:col-span-1 bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                            <option value="">Assign Warehouse</option>
                            @foreach (var wh in Model.Warehouses)
                            {
                                <option value="@wh.WarehouseId">@wh.Name</option>
                            }
                        </select>

                        <button type="submit" class="md:col-span-1 inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-sky-600 text-white text-sm font-semibold hover:bg-sky-500 transition">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                            </svg>
                            <span>Add User</span>
                        </button>
                    </form>
                </div>

                <div class="rounded-xl border border-slate-200 p-4 mb-4">
                    <h4 class="font-semibold text-slate-900 mb-3">Filter Users</h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <input type="text"
                               x-model="userSearch"
                               placeholder="Search by name or email"
                               class="bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500" />
                        <select x-model="roleFilter"
                                class="bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                            <option value="all">All Roles</option>
                            <option value="manager">Manager</option>
                            <option value="staff">Staff</option>
                            <option value="driver">Driver</option>
                        </select>
                        <select x-model="statusFilter"
                                class="bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                            <option value="all">All Statuses</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead>
                            <tr class="text-left text-slate-500 border-b border-slate-200">
                                <th class="py-2 pr-3">Name</th>
                                <th class="py-2 pr-3">Email</th>
                                <th class="py-2 pr-3">Role</th>
                                <th class="py-2 pr-3">Warehouse</th>
                                <th class="py-2 pr-3">Status</th>
                                <th class="py-2 pr-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr x-show="matchesRow($el)"
                                    data-name="@($"{user.FullName} {user.Email}")"
                                    data-role="@user.Role.ToLower()"
                                    data-status="@(user.IsActive ? "active" : "inactive")"
                                    class="border-b border-slate-100 align-top">
                                    <td class="py-3 pr-3">@user.FullName</td>
                                    <td class="py-3 pr-3">@user.Email</td>
                                    <td class="py-3 pr-3">@user.Role</td>
                                    <td class="py-3 pr-3">
                                        @if (user.Role == "Staff" && Model.UserWarehouseMap.TryGetValue(user.UserId, out var whId))
                                        {
                                            var whName = Model.Warehouses.FirstOrDefault(w => w.WarehouseId == whId)?.Name ?? "—";
                                            <span class="px-2 py-1 rounded-full text-xs bg-violet-100 text-violet-700">@whName</span>
                                        }
                                        else if (user.Role == "Staff")
                                        {
                                            <span class="text-xs text-slate-400 italic">Not assigned</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs text-slate-300">—</span>
                                        }
                                    </td>
                                    <td class="py-3 pr-3">
                                        <span class="px-2 py-1 rounded-full text-xs @(user.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-700")">
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="py-3 pr-3">
                                        <div class="flex flex-col gap-2">
                                            <form method="post" action="@Url.Action("ToggleUserStatus","Admin")" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@user.UserId" />
                                                <button type="submit" class="px-3 py-1.5 rounded-lg border border-slate-300 text-xs font-semibold hover:bg-slate-100 transition">
                                                    @(user.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </form>
                                            <details x-data="{ editRole: '@user.Role' }">
                                                <summary class="cursor-pointer text-xs text-sky-600 font-semibold">Edit user</summary>
                                                <form method="post" action="@Url.Action("UpdateUser","Admin")" class="mt-2 grid grid-cols-1 gap-2">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="UserId" value="@user.UserId" />
                                                    <input type="text" name="FullName" value="@user.FullName" required class="bg-slate-50 border border-slate-300 rounded-lg px-2 py-1.5 text-xs outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500" />
                                                    <input type="email" name="Email" value="@user.Email" required class="bg-slate-50 border border-slate-300 rounded-lg px-2 py-1.5 text-xs outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500" />
                                                    <select name="Role" required x-model="editRole" class="bg-slate-50 border border-slate-300 rounded-lg px-2 py-1.5 text-xs outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                                                        @if (user.Role == "Manager") { <option value="Manager" selected>Manager</option> } else { <option value="Manager">Manager</option> }
                                                        @if (user.Role == "Staff") { <option value="Staff" selected>Staff</option> } else { <option value="Staff">Staff</option> }
                                                        @if (user.Role == "Driver") { <option value="Driver" selected>Driver</option> } else { <option value="Driver">Driver</option> }
                                                    </select>
                                                    @{
                                                        var editWhId = Model.UserWarehouseMap.TryGetValue(user.UserId, out var ewh) ? ewh : 0;
                                                    }
                                                    <select name="WarehouseId" x-show="editRole === 'Staff'" x-bind:required="editRole === 'Staff'" class="bg-slate-50 border border-slate-300 rounded-lg px-2 py-1.5 text-xs outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                                                        <option value="">Assign Warehouse</option>
                                                        @foreach (var wh in Model.Warehouses)
                                                        {
                                                            @if (wh.WarehouseId == editWhId) { <option value="@wh.WarehouseId" selected>@wh.Name</option> } else { <option value="@wh.WarehouseId">@wh.Name</option> }
                                                        }
                                                    </select>
                                                    <div>
                                                        <input type="password" name="NewPassword" placeholder="New password (optional)" class="w-full bg-slate-50 border border-slate-300 rounded-lg px-2 py-1.5 text-xs outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500" />
                                                        <p class="text-[9px] text-slate-500 mt-0.5 leading-tight italic">Requires A-z, 0-9, and symbols (!@@#).</p>
                                                    </div>
                                                    <button type="submit" class="px-3 py-1.5 rounded-lg bg-slate-900 text-white text-xs font-semibold hover:bg-slate-800 transition">Save</button>
                                                </form>
                                            </details>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="settings" x-show="activeModule === 'settings'" class="rounded-2xl bg-white border border-slate-200 p-6 mb-6">
                <h3 class="font-display text-3xl font-bold mb-3">Configure System Settings</h3>
                <p class="text-sm text-slate-600 mb-5">Use this area to manage system-wide behaviors such as security policies, default workflows, role permissions, and module assignments.</p>

                <div class="rounded-xl border border-slate-200 p-4"
                     x-data="{
                        selectedUserId: '',
                        selectedModules: [],
                        isStaffRole: false,
                        syncModules() {
                            const userSelect = this.$refs.userSelect;
                            if (!userSelect || !userSelect.selectedIndex) {
                                this.selectedModules = [];
                                this.isStaffRole = false;
                                return;
                            }
                            const opt = userSelect.options[userSelect.selectedIndex];
                            const role = (opt.dataset.role || '').trim();
                            this.isStaffRole = (role.toLowerCase() === 'staff');

                            try {
                                const raw = opt.dataset.modules || '[]';
                                const parsed = JSON.parse(raw);
                                this.selectedModules = Array.isArray(parsed) ? [...parsed] : [];
                            } catch {
                                this.selectedModules = [];
                            }
                        },
                        init() {
                            this.syncModules();
                        }
                     }">
                    <h4 class="font-semibold text-slate-900 mb-3">Assign Modules to User</h4>
                    <form method="post" action="@Url.Action("AssignModules","Admin")" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="block text-xs text-slate-600 mb-1">Select User</label>
                            <select name="UserId"
                                    x-ref="userSelect"
                                    x-model="selectedUserId"
                                    @@change="syncModules()"
                                    required
                                    class="w-full md:w-80 bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500">
                                <option value="">Choose a user</option>
                                @foreach (var user in Model.Users.Where(u => u.IsActive))
                                {
                                    var assignedModules = Model.UserAssignedModules.TryGetValue(user.UserId, out var modules) ? modules : new List<string>();
                                    <option value="@user.UserId"
                                            data-role="@user.Role"
                                            data-modules='@System.Text.Json.JsonSerializer.Serialize(assignedModules)'>
                                        @user.FullName (@user.Role)
                                    </option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-xs text-slate-600 mb-2">Modules</label>
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-sm">
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Dashboard" class="accent-sky-600" /> Dashboard</label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Shipments" class="accent-sky-600" /> Shipments</label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Routes" class="accent-sky-600" /> Routes</label>
                                <label class="flex items-center gap-2">
                                    <input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Warehouses" class="accent-sky-600" />
                                    <span x-text="isStaffRole ? 'Facility Hub (Staff POV)' : 'Warehouses (Mgmt POV)'"></span>
                                </label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Tracking" class="accent-sky-600" /> Tracking</label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Freight Costs" class="accent-sky-600" /> Freight Costs</label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Reports" class="accent-sky-600" /> Reports</label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="System Settings" class="accent-sky-600" /> System Settings</label>
                                <label class="flex items-center gap-2"><input type="checkbox" x-model="selectedModules" name="SelectedModules" value="Audit Logs" class="accent-sky-600" /> Audit Logs</label>
                            </div>
                        </div>

                        <button type="submit" class="px-4 py-2 rounded-lg bg-sky-600 text-white text-sm font-semibold hover:bg-sky-500 transition">
                            Save
                        </button>
                        <p class="text-xs text-slate-500">
                            Select a user to load currently assigned modules, then check/uncheck and save.
                        </p>
                    </form>
                </div>
            </section>

            <section id="modules" x-show="activeModule === 'modules'" class="rounded-2xl bg-white border border-slate-200 p-6 mb-6">
                <h3 class="font-display text-3xl font-bold mb-3">Access All Modules</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Shipments: <span class="font-semibold">@Model.TotalShipments</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Routes: <span class="font-semibold">@Model.TotalRoutes</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Warehouses: <span class="font-semibold">@Model.TotalWarehouses</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Carriers: <span class="font-semibold">@Model.TotalCarriers</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Invoices: <span class="font-semibold">@Model.TotalInvoices</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Tracking Events: <span class="font-semibold">@Model.TotalTrackingEvents</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">Pending Shipments: <span class="font-semibold">@Model.PendingShipments</span></div>
                    <div class="p-3 rounded-lg bg-slate-50 border border-slate-200">In Transit: <span class="font-semibold">@Model.InTransitShipments</span></div>
                </div>
            </section>

            <section id="logs" x-show="activeModule === 'logs'" class="rounded-2xl bg-white border border-slate-200">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h3 class="font-display text-3xl font-bold">View Reports and Logs</h3>
                </div>
                <div id="audit-log-list" class="divide-y divide-slate-100">
                    @if (Model.RecentActivities.Count == 0)
                    {
                        <p id="audit-empty-state" class="px-6 py-6 text-slate-500">No activity logs yet.</p>
                    }
                    else
                    {
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <div class="px-6 py-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="font-medium text-slate-800">@activity.Action</p>
                                        <p class="text-sm text-slate-500">
                                            by @(activity.User?.FullName ?? "Unknown user")
                                            @if (!string.IsNullOrWhiteSpace(activity.TableAffected))
                                            {
                                                <text> - @activity.TableAffected</text>
                                            }
                                        </p>
                                    </div>
                                    <span class="text-xs text-slate-400 whitespace-nowrap">@activity.Timestamp.ToString("MMM dd, hh:mm tt")</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>
        </main>
    </div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const roleCtx = document.getElementById('usersByRoleChart');
            const opsCtx = document.getElementById('opsStatusChart');

            if (roleCtx) {
                new Chart(roleCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Admin', 'Manager', 'Finance', 'Staff', 'Driver'],
                        datasets: [{
                            data: [
                                @Model.AdminUsers,
                                @Model.ManagerUsers,
                                @Model.FinanceUsers,
                                @Model.StaffUsers,
                                @Model.DriverUsers
                            ],
                            backgroundColor: ['#2563eb', '#06b6d4', '#7c3aed', '#16a34a', '#f59e0b']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            }

            if (opsCtx) {
                new Chart(opsCtx, {
                    type: 'bar',
                    data: {
                        labels: ['Pending', 'In Transit', 'Carriers', 'Warehouses', 'Routes', 'Invoices'],
                        datasets: [{
                            label: 'Count',
                            data: [
                                @Model.PendingShipments,
                                @Model.InTransitShipments,
                                @Model.TotalCarriers,
                                @Model.TotalWarehouses,
                                @Model.TotalRoutes,
                                @Model.TotalInvoices
                            ],
                            backgroundColor: '#0ea5e9'
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                        plugins: { legend: { display: false } }
                    }
                });
            }

            const logList = document.getElementById('audit-log-list');
            const emptyState = document.getElementById('audit-empty-state');
            const htmlEscape = (value) => String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');

            const formatTime = (timestamp) => {
                const date = timestamp ? new Date(timestamp) : new Date();
                if (Number.isNaN(date.getTime())) return '';
                return date.toLocaleString([], {
                    month: 'short',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: true
                });
            };

            const renderLogItem = (entry) => {
                const action = entry.action ?? entry.Action ?? '';
                const tableAffected = entry.tableAffected ?? entry.TableAffected ?? '';
                const userFullName = entry.userFullName ?? entry.UserFullName ?? 'Unknown user';
                const timestamp = entry.timestamp ?? entry.Timestamp;
                return `
                    <div class="px-6 py-4">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="font-medium text-slate-800">${htmlEscape(action)}</p>
                                <p class="text-sm text-slate-500">
                                    by ${htmlEscape(userFullName)}
                                    ${tableAffected ? ` - ${htmlEscape(tableAffected)}` : ''}
                                </p>
                            </div>
                            <span class="text-xs text-slate-400 whitespace-nowrap">${htmlEscape(formatTime(timestamp))}</span>
                        </div>
                    </div>
                `;
            };

            if (window.signalR && logList) {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/audit-log')
                    .withAutomaticReconnect()
                    .build();

                connection.on('auditLogCreated', (entry) => {
                    if (emptyState) {
                        emptyState.remove();
                    }
                    logList.insertAdjacentHTML('afterbegin', renderLogItem(entry));
                    while (logList.children.length > 20) {
                        logList.removeChild(logList.lastElementChild);
                    }
                });

                connection.start().catch(() => {
                    // Keep the dashboard usable even if the real-time stream fails.
                });
            }
        });
    </script>
}
