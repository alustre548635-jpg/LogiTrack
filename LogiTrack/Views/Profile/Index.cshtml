@model LogiTrack.Models.ViewModels.ProfileIndexViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "_ModuleLayout";
    var user = Model.User;
    var staff = Model.Staff;
    var userRoleLower = (user.Role ?? "").ToLower().Replace(" ", "");
    bool isSystemAdmin = userRoleLower == "admin" || userRoleLower == "superadmin";
}

@{
    string backUrl = Url.Action("Index", "Client");
    if (string.Equals(user.Role, "Admin", StringComparison.OrdinalIgnoreCase)) backUrl = Url.Action("Index", "Admin");
    else if (string.Equals(user.Role, "Manager", StringComparison.OrdinalIgnoreCase)) backUrl = Url.Action("Index", "Manager");
    else if (string.Equals(user.Role, "Driver", StringComparison.OrdinalIgnoreCase)) backUrl = Url.Action("Index", "Driver");
    else if (string.Equals(user.Role, "Staff", StringComparison.OrdinalIgnoreCase) || string.Equals(user.Role, "Warehouse Staff", StringComparison.OrdinalIgnoreCase)) backUrl = Url.Action("Index", "Warehouse");
}

<div class="p-6 max-w-6xl mx-auto" x-data="profileModule()">
    <div class="mb-6">
        <a href="@backUrl" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-all shadow-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Back to Dashboard
        </a>
    </div>
    <!-- Header Area -->
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-center gap-6">
            <div class="relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-sky-500 to-orange-500 rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-1000"></div>
                <div class="relative w-24 h-24 md:w-32 md:h-32 bg-slate-900 rounded-3xl flex items-center justify-center text-white overflow-hidden border border-white/10 shadow-2xl">
                    <svg class="w-12 h-12 md:w-16 md:h-16 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <!-- Overlay for change photo (Mock) -->
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer">
                        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    </div>
                </div>
            </div>
            <div>
                <h2 class="text-3xl font-display font-bold text-slate-900">@user.FullName</h2>
                <div class="flex items-center gap-2 mt-2">
                    <span class="px-3 py-1 rounded-full bg-sky-50 text-sky-600 text-xs font-bold border border-sky-100 uppercase tracking-wider">@user.Role</span>
                    <span class="text-slate-400">•</span>
                    <span class="text-sm text-slate-500">Member since @user.CreatedAt.ToString("MMMM yyyy")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex gap-1 bg-slate-100 p-1 rounded-2xl mb-8 w-fit overflow-x-auto no-scrollbar">
        <template x-for="tab in filteredTabs" :key="tab.id">
            <button @@click="activeTab = tab.id"
                    :class="activeTab === tab.id ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'"
                    class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all whitespace-nowrap flex items-center gap-2">
                <span x-html="tab.icon"></span>
                <span x-text="tab.label"></span>
            </button>
        </template>
    </div>

    <!-- TAB CONTENT -->
    <div class="grid grid-cols-1 gap-8">
        
        <!-- IDENTITY TAB (Universal) -->
        <div x-show="activeTab === 'identity'" x-transition class="space-y-6">
            <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    Personal Information
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase ml-1">Full Name</label>
                        <input type="text" x-model="formData.fullName" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500 outline-none transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase ml-1">Email Address</label>
                        <input type="email" x-model="formData.email" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500 outline-none transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase ml-1">Phone Number</label>
                        <input type="text" x-model="formData.phoneNumber" placeholder="e.g. +63 912 345 6789" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500 outline-none transition-all" />
                    </div>
                </div>
                <div class="mt-8 flex justify-end">
                    <button @@click="saveIdentity()" :disabled="loading" class="px-8 py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-slate-800 transition-all flex items-center gap-2 shadow-lg shadow-slate-900/10">
                        <svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Update Identity
                    </button>
                </div>
            </div>
        </div>

        <!-- OPERATIONAL TAB (Managers / Staff / Drivers) -->
        @if (!isSystemAdmin)
        {
            <div x-show="activeTab === 'operational'" x-transition class="space-y-6">
                @if (user.Role == "Driver")
                {
                    var driver = Model.Driver;
                    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                        <!-- Assigned Vehicle -->
                        <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                            <div class="flex items-center justify-between mb-6">
                                <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                    <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" /><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" /></svg>
                                    Assigned Vehicle
                                </h3>
                                <span class="px-3 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-bold rounded-lg border border-emerald-100 uppercase tracking-widest">Active Duty</span>
                            </div>

                            @if (driver != null)
                            {
                                <div class="space-y-6">
                                    <div class="p-5 bg-slate-900 rounded-2xl text-white relative overflow-hidden">
                                        <svg class="absolute -right-4 -bottom-4 w-24 h-24 text-white/5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" /></svg>
                                        <p class="text-[10px] font-bold text-white/40 uppercase tracking-widest mb-1">Vehicle Details</p>
                                        <h4 class="text-xl font-bold">@driver.VehiclePlate</h4>
                                        <p class="text-xs text-white/60">@driver.VehicleType</p>
                                    </div>
                                    <div class="flex items-center justify-between px-2">
                                        <a href="#" class="text-xs font-bold text-indigo-600 hover:underline">View Maintenance Status</a>
                                        <span class="text-[10px] text-slate-400 font-bold uppercase">Next Service: 12 Oct</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-sm text-slate-500 italic">No vehicle currently assigned.</p>
                            }
                        </div>

                        <!-- License Tracker -->
                        <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                            <h3 class="text-lg font-bold text-slate-900 mb-8 flex items-center gap-2">
                                <svg class="w-5 h-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>
                                Compliance Status
                            </h3>
                            
                            @if (driver != null)
                            {
                                var daysUntilExpiry = driver.LicenseExpiry.HasValue ? (driver.LicenseExpiry.Value - DateTime.Now).Days : 999;
                                <div class="space-y-6">
                                    <div class="space-y-1">
                                        <p class="text-[10px] font-bold text-slate-400 uppercase ml-1">Driver's License</p>
                                        <p class="text-lg font-bold text-slate-900">@driver.LicenseNumber</p>
                                    </div>
                                    
                                    <div class="p-4 rounded-2xl @(daysUntilExpiry < 30 ? "bg-rose-50 border border-rose-100" : "bg-slate-50 border border-slate-200")">
                                        <div class="flex items-center justify-between mb-2">
                                            <span class="text-[10px] font-bold @(daysUntilExpiry < 30 ? "text-rose-600" : "text-slate-500") uppercase">License Expiry</span>
                                            <span class="text-[10px] font-bold @(daysUntilExpiry < 30 ? "text-rose-600" : "text-emerald-600")">@(daysUntilExpiry < 0 ? "EXPIRED" : daysUntilExpiry + " DAYS LEFT")</span>
                                        </div>
                                        <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                                            <div class="h-full @(daysUntilExpiry < 30 ? "bg-rose-500" : "bg-emerald-500")" style="width: @(Math.Min(100, Math.Max(0, (daysUntilExpiry / 365.0) * 100)))%"></div>
                                        </div>
                                        <p class="text-[10px] text-slate-500 mt-2">Valid until @(driver.LicenseExpiry?.ToString("MMM dd, yyyy") ?? "N/A")</p>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Driver Ratings -->
                        <div class="bg-indigo-900 rounded-3xl p-8 text-white shadow-xl relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent pointer-events-none"></div>
                            <h3 class="text-lg font-bold mb-8 flex items-center gap-2">
                                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                                Driver Rating
                            </h3>
                            
                            @if (driver != null)
                            {
                                <div class="space-y-8 relative">
                                    <div class="flex items-end gap-2">
                                        <span class="text-5xl font-display font-bold">@driver.OnTimeDeliveryRate.ToString("0")%</span>
                                        <span class="text-xs text-white/60 mb-2">On-Time Rate</span>
                                    </div>

                                    <div class="space-y-4 pt-4 border-t border-white/10">
                                        <div class="space-y-2">
                                            <div class="flex justify-between text-[10px] font-bold uppercase tracking-wider">
                                                <span class="text-white/60">Safety Score</span>
                                                <span class="text-amber-400">@driver.SafetyScore/100</span>
                                            </div>
                                            <div class="h-1 bg-white/10 rounded-full overflow-hidden">
                                                <div class="h-full bg-amber-400" style="width: @(driver.SafetyScore)%"></div>
                                            </div>
                                        </div>
                                        <p class="text-[10px] text-white/40 leading-relaxed italic text-center">Maintain a score above 90 to qualify for quarterly performance bonuses.</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                        <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                            <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                            Operational Assignment
                        </h3>
                        
                        @if (staff != null)
                        {
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                <div class="bg-slate-50 border border-slate-200 p-5 rounded-2xl">
                                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Facility Oversight</p>
                                    <p class="text-lg font-bold text-slate-900">@staff.Warehouse?.Name</p>
                                    <p class="text-xs text-slate-500 mt-1">Primary Hub: @staff.Warehouse?.Location</p>
                                </div>
                                <div class="bg-slate-50 border border-slate-200 p-5 rounded-2xl">
                                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Managerial Scope</p>
                                    <p class="text-lg font-bold text-slate-900">@(string.IsNullOrEmpty(staff.Zone) ? "General Area" : staff.Zone)</p>
                                    <p class="text-xs text-slate-500 mt-1">Status: <span class="text-emerald-600 font-bold">Authorized Level 2</span></p>
                                </div>
                                <div class="bg-slate-50 border border-slate-200 p-5 rounded-2xl">
                                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Work Schedule</p>
                                    <p class="text-lg font-bold text-slate-900">@(staff.ShiftType ?? "Morning Shift")</p>
                                    <p class="text-xs text-slate-500 mt-1">Status: <span class="@(staff.IsOnShift ? "text-emerald-600" : "text-amber-600") font-bold">@(staff.IsOnShift ? "ON DUTY" : "OFF DUTY")</span></p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="bg-amber-50 border border-amber-100 p-8 rounded-2xl flex items-center gap-4">
                                <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-amber-600">
                                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-amber-900">Assignment Pending</p>
                                    <p class="text-xs text-amber-700">No warehouse assignment found for this account. Please contact an Administrator.</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- GOVERNANCE TAB (Admins / Super Admins) -->
        @if (isSystemAdmin)
        {
            <div x-show="activeTab === 'governance'" x-transition class="space-y-6">
                <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                    <!-- Global Permissions -->
                    <div class="xl:col-span-2 bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                        <div class="flex items-center justify-between mb-8">
                            <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                                System Governance
                            </h3>
                            <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[10px] font-bold rounded-lg border border-indigo-100 uppercase tracking-widest">Master Control</span>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-4">
                                <p class="text-xs font-bold text-slate-500 uppercase ml-1">Assigned Capabilities</p>
                                <div class="grid grid-cols-1 gap-2">
                                    <template x-for="perm in permissions" :key="perm">
                                        <div class="flex items-center justify-between px-4 py-3 bg-slate-50 border border-slate-200/50 rounded-xl">
                                            <div class="flex items-center gap-3">
                                                <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                                                <span class="text-xs font-bold text-slate-700" x-text="perm"></span>
                                            </div>
                                            <span class="text-[9px] font-bold text-slate-400 uppercase">ACTIVE</span>
                                        </div>
                                    </template>
                                </div>
                            </div>
                            
                            <div class="space-y-6">
                                <div class="bg-indigo-600 rounded-2xl p-6 text-white shadow-xl shadow-indigo-600/20 relative overflow-hidden">
                                    <svg class="absolute -right-4 -bottom-4 w-24 h-24 text-white/10" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" /></svg>
                                    <p class="text-xs font-bold text-white/60 uppercase tracking-widest mb-1">Security Level</p>
                                    <h4 class="text-2xl font-display font-bold">Tier 1 Administrator</h4>
                                    <p class="text-[10px] text-white/80 mt-2 leading-relaxed">Full cryptographic access to system variables, user auditing, and global configuration overrides.</p>
                                </div>

                                <div class="p-5 border border-slate-200 rounded-2xl bg-slate-50/50">
                                    <p class="text-xs font-bold text-slate-500 uppercase mb-4">Audit Summary (Last 24h)</p>
                                    <div class="space-y-3">
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs text-slate-600">Config Changes</span>
                                            <span class="text-xs font-bold text-slate-900">12</span>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs text-slate-600">User Authorizations</span>
                                            <span class="text-xs font-bold text-slate-900">08</span>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs text-slate-600">Security Overrides</span>
                                            <span class="text-xs font-bold text-emerald-600">NONE</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- System Pulse -->
                    <div class="bg-slate-900 rounded-3xl p-8 text-white shadow-2xl relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/20 to-transparent pointer-events-none"></div>
                        <h3 class="text-lg font-bold mb-8 flex items-center gap-2 relative">
                            <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                            System Pulse
                        </h3>
                        
                        <div class="space-y-6 relative">
                            <div class="space-y-2">
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-slate-400 font-bold uppercase tracking-widest">Environment</span>
                                    <span class="text-emerald-400 font-bold">PRODUCTION</span>
                                </div>
                                <div class="h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                    <div class="h-full bg-emerald-500 w-full"></div>
                                </div>
                            </div>
                            
                            <div class="space-y-2">
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-slate-400 font-bold uppercase tracking-widest">API Health</span>
                                    <span class="text-sky-400 font-bold">99.9% Uptime</span>
                                </div>
                                <div class="h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                    <div class="h-full bg-sky-500 w-[99.9%]"></div>
                                </div>
                            </div>

                            <div class="space-y-2">
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-slate-400 font-bold uppercase tracking-widest">Database Load</span>
                                    <span class="text-amber-400 font-bold">OPTIMAL</span>
                                </div>
                                <div class="h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                    <div class="h-full bg-amber-500 w-1/4"></div>
                                </div>
                            </div>

                            <div class="pt-6 mt-6 border-t border-white/5 space-y-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-indigo-400">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-[10px] font-bold text-slate-400 uppercase leading-tight">Master API Key</p>
                                        <p class="text-xs font-mono text-white/80 mt-1 truncate">LT_SK_********************</p>
                                    </div>
                                </div>
                                <button class="w-full py-3 bg-white/5 hover:bg-white/10 text-xs font-bold rounded-xl transition-all border border-white/5">
                                    View Global Audit Logs
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- SECURITY TAB -->
        <div x-show="activeTab === 'security'" x-transition class="space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Change Password -->
                <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                    <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                        <svg class="w-5 h-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                        Change Password
                    </h3>
                    <div class="space-y-5">
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Current Password</label>
                            <input type="password" x-model="securityData.currentPassword" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none transition-all" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-500 uppercase ml-1">New Password</label>
                            <input type="password" x-model="securityData.newPassword" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none transition-all" />
                            <p class="text-[10px] text-slate-500 mt-1 italic ml-1">Must contain uppercase, lowercase, numbers, and symbols.</p>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Confirm New Password</label>
                            <input type="password" x-model="securityData.confirmPassword" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none transition-all" />
