                                <svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                Save New Password
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 2FA & Sessions -->
                <div class="space-y-8">
                    <!-- 2FA Mock -->
                    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                                Two-Factor Authentication
                            </h3>
                            <button @@click="twoFactor = !twoFactor" :class="twoFactor ? 'bg-emerald-500' : 'bg-slate-200'" class="w-12 h-6 rounded-full relative transition-colors">
                                <div :class="twoFactor ? 'translate-x-6' : 'translate-x-1'" class="absolute top-1 w-4 h-4 bg-white rounded-full transition-transform"></div>
                            </button>
                        </div>
                        <p class="text-xs text-slate-500 leading-relaxed">Secure your account with an extra layer of protection. When enabled, you'll need to provide a code from your mobile app when signing in from a new device.</p>
                        <div x-show="twoFactor" x-transition class="mt-6 p-4 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center gap-4">
                            <div class="w-10 h-10 bg-emerald-500/10 rounded-xl flex items-center justify-center text-emerald-600">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-emerald-800">2FA is currently active</p>
                                <p class="text-[10px] text-emerald-600">Verification via Google Authenticator</p>
                            </div>
                        </div>
                    </div>

                    <!-- Sessions Mock -->
                    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                        <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                            <svg class="w-5 h-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            Active Sessions
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200/50">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 bg-sky-100 rounded-lg flex items-center justify-center text-sky-600">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-slate-900">Chrome on Windows</p>
                                        <p class="text-[10px] text-emerald-600 font-bold">CURRENT SESSION</p>
                                    </div>
                                </div>
                                <span class="text-[10px] text-slate-400 font-mono">192.168.1.42</span>
                            </div>
                            <div class="flex items-center justify-between p-3 rounded-xl border border-slate-100">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center text-slate-500">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-xs font-bold text-slate-900">iPhone 14 Pro</p>
                                        <p class="text-[10px] text-slate-400">2 hours ago</p>
                                    </div>
                                </div>
                                <button class="text-[10px] font-bold text-rose-500 hover:underline">Revoke</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PREFERENCES TAB -->
        <div x-show="activeTab === 'preferences'" x-transition class="space-y-6">
            <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    Interface Preferences
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-500 uppercase ml-1">System Language</label>
                            <select x-model="preferences.language" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all">
                                <option value="en">English (US)</option>
                                <option value="ph">Tagalog (PH)</option>
                                <option value="es">Spanish</option>
                            </select>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Work Timezone</label>
                            <select class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all">
                                <option>(GMT+08:00) Manila, Beijing, Singapore</option>
                                <option>(GMT+00:00) UTC</option>
                            </select>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <p class="text-xs font-bold text-slate-500 uppercase ml-1">Notifications</p>
                        <label class="flex items-center gap-3 p-4 bg-slate-50 border border-slate-100 rounded-2xl cursor-pointer hover:border-indigo-200 transition-all">
                            <input type="checkbox" x-model="preferences.emailNotifications" class="w-5 h-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500/20" />
                            <div>
                                <p class="text-sm font-bold text-slate-900">Email Alerts</p>
                                <p class="text-[11px] text-slate-500">Receive shipment delays and system maintenance reports via email.</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 p-4 bg-slate-50 border border-slate-100 rounded-2xl cursor-pointer hover:border-indigo-200 transition-all">
                            <input type="checkbox" x-model="preferences.smsNotifications" class="w-5 h-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500/20" />
                            <div>
                                <p class="text-sm font-bold text-slate-900">SMS Notifications</p>
                                <p class="text-[11px] text-slate-500">Get critical route optimization alerts directly on your phone.</p>
                            </div>
                        </label>
                    </div>
                </div>
                <div class="mt-12 pt-8 border-t border-slate-100 flex justify-end">
                    <button @@click="savePreferences()" class="px-8 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition-all flex items-center gap-2 shadow-lg shadow-indigo-600/10">
                        Apply Preferences
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    function profileModule() {
        return {
            activeTab: '@(isSystemAdmin ? "governance" : "identity")',
            loading: false,
            twoFactor: true,
            userRole: '@user.Role',
            tabs: [
                { id: 'identity', label: 'Identity', icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>' },
                { id: 'operational', label: 'Operational', icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>' },
                { id: 'governance', label: 'Governance', icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>' },
                { id: 'security', label: 'Security', icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>' },
                { id: 'preferences', label: 'Preferences', icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>' }
            ],
            permissions: ['User Management', 'Fleet Config', 'Billing Access', 'System Logs', 'API Keys', 'Global Settings'],

            get filteredTabs() {
                const role = this.userRole.toLowerCase().replace(' ', '');
                const isSysAdmin = role === 'admin' || role === 'superadmin';
                return this.tabs.filter(t => {
                    if (isSysAdmin) return t.id !== 'operational';
                    return t.id !== 'governance';
                });
            },
            formData: {
                fullName: '@user.FullName',
                email: '@user.Email',
                phoneNumber: '@(user.PhoneNumber ?? "")'
            },
            securityData: {
                currentPassword: '',
                newPassword: '',
                confirmPassword: ''
            },
            preferences: {
                emailNotifications: true,
                smsNotifications: false,
                language: 'en'
            },

            async saveIdentity() {
                this.loading = true;
                const form = new FormData();
                form.append('fullName', this.formData.fullName);
                form.append('email', this.formData.email);
                form.append('phoneNumber', this.formData.phoneNumber);
                form.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                try {
                    const res = await fetch('@Url.Action("UpdateIdentity", "Profile")', { method: 'POST', body: form });
                    const data = await res.json();
                    if (data.success) {
                        window.showToast(data.message, 'success');
                    } else {
                        window.showToast(data.message, 'error');
                    }
                } catch (e) {
                    window.showToast('Network error', 'error');
                } finally {
                    this.loading = false;
                }
            },

            async changePassword() {
                if (this.securityData.newPassword !== this.securityData.confirmPassword) {
                    window.showToast('Passwords do not match', 'error');
                    return;
                }

                this.loading = true;
                const form = new FormData();
                form.append('currentPassword', this.securityData.currentPassword);
                form.append('newPassword', this.securityData.newPassword);
                form.append('confirmPassword', this.securityData.confirmPassword);
                form.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                try {
                    const res = await fetch('@Url.Action("ChangePassword", "Profile")', { method: 'POST', body: form });
                    const data = await res.json();
                    if (data.success) {
                        window.showToast(data.message, 'success');
                        this.securityData = { currentPassword: '', newPassword: '', confirmPassword: '' };
                    } else {
                        window.showToast(data.message, 'error');
                    }
                } catch (e) {
                    window.showToast('Network error', 'error');
                } finally {
                    this.loading = false;
                }
            },

            async savePreferences() {
                const form = new FormData();
                form.append('emailNotifications', this.preferences.emailNotifications);
                form.append('smsNotifications', this.preferences.smsNotifications);
                form.append('language', this.preferences.language);

                const res = await fetch('@Url.Action("UpdatePreferences", "Profile")', { method: 'POST', body: form });
                const data = await res.json();
                window.showToast(data.message, 'success');
            }
        }
    }
</script>

@Html.AntiForgeryToken()
